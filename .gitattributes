# Keep GitHub language stats focused on authored source code

# Third-party frontend libraries (vendor code)
TourMap/TourMap.AdminWeb/wwwroot/lib/** linguist-vendored

# Generated uploads and runtime data
TourMap/TourMap.AdminWeb/wwwroot/uploads/** linguist-generated
TourMap/TourMap.AdminWeb/App_Data/** linguist-generated

# Build outputs
**/bin/** linguist-generated
**/obj/** linguist-generated

# Docs and presentation artifacts (exclude from language stats)
TourMap/_docs/** linguist-documentation

# Treat Razor views as C#-side source instead of plain HTML for repo language stats
*.cshtml linguist-language=C#

# Optional: keep standalone HTML assets out of detected language mix
*.html linguist-detectable=false
