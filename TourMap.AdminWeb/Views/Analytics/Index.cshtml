@model TourMap.AdminWeb.ViewModels.AnalyticsDashboardViewModel
@using System.Text.Json;

@{
    ViewData["Title"] = "Analytics Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Analytics Dashboard</h2>
    <div class="d-flex align-items-center gap-3">
        <a asp-action="ExportCsv" asp-route-days="30" class="btn btn-sm btn-outline-primary">Export CSV (30 days)</a>
        <span class="text-muted">Last update: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</span>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm border-0 bg-primary text-white">
            <div class="card-body">
                <div class="text-white-50">Total plays (7 days)</div>
                <div class="fs-3 fw-bold">@Model.TotalPlays7Days</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 bg-info text-white">
            <div class="card-body">
                <div class="text-white-50">Total plays (30 days)</div>
                <div class="fs-3 fw-bold">@Model.TotalPlays30Days</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 bg-success text-white">
            <div class="card-body">
                <div class="text-white-50">Avg duration (sec)</div>
                <div class="fs-3 fw-bold">@Model.AverageDurationSeconds</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm border-0 bg-warning text-dark">
            <div class="card-body">
                <div class="text-dark-50">Completion rate</div>
                <div class="fs-3 fw-bold">@Model.CompletionRatePercent%</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <!-- Heat Map -->
    <div class="col-12">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-white fw-semibold">User Activity Heat Map (Last 7 Days)</div>
            <div class="card-body p-0">
                <div id="heatmap" style="height: 400px; width: 100%; border-bottom-left-radius: .25rem; border-bottom-right-radius: .25rem;"></div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <!-- Top 10 POIs -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Top 10 POI (7 days)</div>
            <div class="card-body p-0">
                <table class="table table-striped table-sm mb-0 border-0">
                    <thead class="table-light">
                        <tr>
                            <th>POI</th>
                            <th class="text-end">Plays</th>
                        </tr>
                    </thead>
                    <tbody>
                    @if (Model.TopPois7Days.Count == 0)
                    {
                        <tr><td colspan="2" class="text-center text-muted py-3">No data</td></tr>
                    }
                    else
                    {
                        @foreach (var item in Model.TopPois7Days)
                        {
                            <tr>
                                <td class="ps-3">@item.PoiTitle</td>
                                <td class="text-end pe-3">@item.PlayCount</td>
                            </tr>
                        }
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Trigger Breakdown Chart -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Trigger breakdown (7 days)</div>
            <div class="card-body d-flex justify-content-center align-items-center">
                @if(Model.TriggerTypeBreakdown7Days.Count == 0) {
                    <div class="text-muted">No data</div>
                } else {
                    <canvas id="triggerChart" style="max-height: 250px"></canvas>
                }
            </div>
        </div>
    </div>

    <!-- Daily Plays Chart -->
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">Daily plays (7 days)</div>
            <div class="card-body">
                @if(Model.DailyPlays7Days.Count == 0) {
                    <div class="text-center text-muted">No data</div>
                } else {
                    <canvas id="dailyChart"></canvas>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- Leaflet & Heatmap -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin=""/>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>
    <script src="https://unpkg.com/leaflet.heat@0.2.0/dist/leaflet-heat.js"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // Heatmap logic
            var heatmapPoints = @Json.Serialize(Model.HeatmapPoints);
            var map = L.map('heatmap', {
                center: [10.762622, 106.660172], // Default to HCMC
                zoom: 13
            });
            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors &copy; <a href="https://carto.com/attributions">CARTO</a>',
                subdomains: 'abcd',
                maxZoom: 20
            }).addTo(map);

            if (heatmapPoints.length > 0) {
                var heatData = heatmapPoints.map(p => [p.lat, p.lng, p.intensity]);
                L.heatLayer(heatData, {radius: 25, blur: 15, maxZoom: 17}).addTo(map);
                
                // Adjust bounds to fit data
                var bounds = L.latLngBounds(heatmapPoints.map(p => [p.lat, p.lng]));
                map.fitBounds(bounds, {padding: [50, 50]});
            }

            // Trigger Pie Chart
            var rawTriggers = @Json.Serialize(Model.TriggerTypeBreakdown7Days);
            if (rawTriggers && rawTriggers.length > 0) {
                var ctx1 = document.getElementById('triggerChart').getContext('2d');
                new Chart(ctx1, {
                    type: 'doughnut',
                    data: {
                        labels: rawTriggers.map(t => t.triggerType),
                        datasets: [{
                            data: rawTriggers.map(t => t.count),
                            backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#dc3545', '#6c757d']
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { position: 'bottom' } }
                    }
                });
            }

            // Daily Line Chart
            var rawDaily = @Json.Serialize(Model.DailyPlays7Days);
            if (rawDaily && rawDaily.length > 0) {
                var ctx2 = document.getElementById('dailyChart').getContext('2d');
                new Chart(ctx2, {
                    type: 'line',
                    data: {
                        labels: rawDaily.map(d => new Date(d.day).toLocaleDateString()),
                        datasets: [{
                            label: 'Plays',
                            data: rawDaily.map(d => d.count),
                            borderColor: '#0d6efd',
                            backgroundColor: 'rgba(13, 110, 253, 0.1)',
                            fill: true,
                            tension: 0.3
                        }]
                    },
                    options: {
                        responsive: true,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true, ticks: { stepSize: 1 } } }
                    }
                });
            }
        });
    </script>
}
