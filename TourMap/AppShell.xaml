<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="TourMap.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:TourMap.Pages"
    xmlns:services="clr-namespace:TourMap.Services"
    xmlns:local="clr-namespace:TourMap"
    Shell.TabBarBackgroundColor="#1A237E"
    Shell.TabBarForegroundColor="White"
    Shell.TabBarTitleColor="White"
    Shell.TabBarUnselectedColor="#B0BEC5">

    <TabBar>
        <ShellContent
            Title="{Binding [MapBtn], Source={x:Static services:LocalizationService.Current}}"
            ContentTemplate="{DataTemplate pages:MapPage}"
            Route="MapPage" />

        <ShellContent
            Title="{Binding [QrBtn], Source={x:Static services:LocalizationService.Current}}"
            ContentTemplate="{DataTemplate pages:QrScannerPage}"
            Route="QrScannerPage" />

        <ShellContent
            Title="{Binding [SettingsTitle], Source={x:Static services:LocalizationService.Current}}"
            ContentTemplate="{DataTemplate pages:SettingsPage}"
            Route="SettingsPage" />
    </TabBar>

</Shell>

