<?xml version="1.0" encoding="UTF-8"?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourMap.Pages.Tours.TourDetailPage"
             Title="Chi tiết Tour"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A1A}">
    
    <ContentPage.Resources>
        <ResourceDictionary>
            <Style x:Key="PoiItem" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=White, Dark=#2D2D2D}" />
                <Setter Property="Padding" Value="16" />
                <Setter Property="Margin" Value="16,6" />
            </Style>
        </ResourceDictionary>
    </ContentPage.Resources>

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <!-- Tour Header -->
            <Frame x:Name="TourHeader"
                   BackgroundColor="#667eea"
                   Padding="20,24"
                   CornerRadius="0">
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="TourName"
                           FontSize="24"
                           FontAttributes="Bold"
                           TextColor="White"
                           HorizontalOptions="Center" />
                    
                    <Label x:Name="TourDescription"
                           FontSize="14"
                           TextColor="#E8E8E8"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           LineBreakMode="WordWrap" />

                    <!-- Progress -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <ProgressBar x:Name="ProgressBar"
                                     ProgressColor="#4CAF50"
                                     HeightRequest="6"
                                     VerticalOptions="Center" />
                        <Label x:Name="ProgressText"
                               Grid.Column="1"
                               FontSize="12"
                               TextColor="White"
                               Margin="8,0,0,0"
                               VerticalOptions="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

            <!-- Start Tour Button -->
            <Button x:Name="StartTourButton"
                    Text="🚀 Bắt đầu Tour"
                    BackgroundColor="#4CAF50"
                    TextColor="White"
                    FontAttributes="Bold"
                    FontSize="16"
                    CornerRadius="8"
                    Margin="16,12"
                    HeightRequest="48"
                    Clicked="OnStartTourClicked" />

            <!-- POI List Header -->
            <Label Text="🍽️ Các quán trong Tour"
                   FontSize="16"
                   FontAttributes="Bold"
                   Margin="16,8,16,0"
                   TextColor="{AppThemeBinding Light=#333, Dark=#FFF}" />

            <!-- POI List -->
            <CollectionView x:Name="PoiCollection"
                             SelectionMode="None"
                             Margin="0,8">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource PoiItem}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            
                            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                                <!-- Order Number -->
                                <Ellipse WidthRequest="36" 
                                         HeightRequest="36" 
                                         Fill="#667eea"
                                         VerticalOptions="Center" />
                                <Label Text="{Binding OrderNumber}"
                                       WidthRequest="36"
                                       HeightRequest="36"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       HorizontalTextAlignment="Center"
                                       VerticalTextAlignment="Center"
                                       TextColor="White"
                                       FontAttributes="Bold"
                                       FontSize="14" />

                                <!-- POI Info -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Title}"
                                           FontSize="16"
                                           FontAttributes="Bold"
                                           TextColor="{AppThemeBinding Light=#333, Dark=#FFF}" />
                                    <Label Text="{Binding Category, TargetNullValue='Ẩm thực'}"
                                           FontSize="12"
                                           TextColor="#667eea" />
                                    <Label Text="{Binding DistanceText, TargetNullValue='Cách bạn ~100m'}"
                                           FontSize="11"
                                           TextColor="{AppThemeBinding Light=#999, Dark=#666}" />
                                </VerticalStackLayout>

                                <!-- Visited Checkbox -->
                                <CheckBox Grid.Column="2"
                                          IsChecked="{Binding IsVisited}"
                                          Color="#4CAF50"
                                          VerticalOptions="Center" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Empty State -->
            <VerticalStackLayout x:Name="EmptyPois"
                                  IsVisible="False"
                                  Margin="40,40">
                <Label Text="🍜"
                       FontSize="64"
                       HorizontalOptions="Center" />
                <Label Text="Chưa có quán nào"
                       FontSize="16"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
