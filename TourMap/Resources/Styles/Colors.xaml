<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- ═══ Figma Design System — Audio Tour App ═══ -->

    <!-- Primary palette -->
    <Color x:Key="Primary">#0D7A5F</Color>
    <Color x:Key="PrimaryLight">#E0F5F0</Color>
    <Color x:Key="PrimaryDark">#065C47</Color>

    <!-- Accent palette -->
    <Color x:Key="Accent">#F5A623</Color>
    <Color x:Key="AccentLight">#FEF6E4</Color>

    <!-- Surfaces -->
    <Color x:Key="Background">#F6F5F1</Color>
    <Color x:Key="Surface">#FFFFFF</Color>

    <!-- Text hierarchy -->
    <Color x:Key="TextPrimary">#18181B</Color>
    <Color x:Key="TextSecondary">#6B7280</Color>
    <Color x:Key="TextHint">#9CA3AF</Color>

    <!-- UI chrome -->
    <Color x:Key="Border">#E4E4E0</Color>
    <Color x:Key="InputBackground">#F3F3F5</Color>
    <Color x:Key="SwitchOff">#D1D5DB</Color>

    <!-- Semantic -->
    <Color x:Key="Success">#22C55E</Color>
    <Color x:Key="Danger">#EF4444</Color>
    <Color x:Key="Warning">#D97706</Color>

    <!-- Category colors -->
    <Color x:Key="CatHeritage">#F5A623</Color>
    <Color x:Key="CatTemple">#8B5CF6</Color>
    <Color x:Key="CatMarket">#2563EB</Color>
    <Color x:Key="CatFood">#EF4444</Color>
    <Color x:Key="CatPark">#22C55E</Color>
    <Color x:Key="CatCulture">#EC4899</Color>

    <!-- Icon backgrounds (from Figma Settings screen) -->
    <Color x:Key="IconBgIndigo">#EEF2FF</Color>
    <Color x:Key="IconBgTeal">#E0F5F0</Color>
    <Color x:Key="IconBgAmber">#FEF3C7</Color>
    <Color x:Key="IconBgPurple">#FDF4FF</Color>
    <Color x:Key="IconBgGreen">#DCFCE7</Color>
    <Color x:Key="IconBgRed">#FEE2E2</Color>

    <!-- Legacy compatibility (keep for Styles.xaml references) -->
    <Color x:Key="White">White</Color>
    <Color x:Key="Black">Black</Color>
    <Color x:Key="OffBlack">#1f1f1f</Color>
    <Color x:Key="Gray100">#E1E1E1</Color>
    <Color x:Key="Gray200">#C8C8C8</Color>
    <Color x:Key="Gray300">#ACACAC</Color>
    <Color x:Key="Gray400">#919191</Color>
    <Color x:Key="Gray500">#6E6E6E</Color>
    <Color x:Key="Gray600">#404040</Color>
    <Color x:Key="Gray900">#212121</Color>
    <Color x:Key="Gray950">#141414</Color>
    <Color x:Key="Magenta">#FF00FF</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource Primary}"/>
    <SolidColorBrush x:Key="PrimaryLightBrush" Color="{StaticResource PrimaryLight}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}"/>
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource Background}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource Surface}"/>
    <SolidColorBrush x:Key="WhiteBrush" Color="{StaticResource White}"/>
    <SolidColorBrush x:Key="BlackBrush" Color="{StaticResource Black}"/>

</ResourceDictionary>