@{
    ViewData["Title"] = "Đăng nhập hệ thống";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-4">
        <div class="card shadow rounded-3 border-0">
            <div class="card-header bg-primary text-white text-center py-3 rounded-top">
                <h4 class="mb-0 fw-bold">🔐 ĐĂNG NHẬP ADMIN</h4>
            </div>
            <div class="card-body p-4 bg-light">
                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger fw-bold text-center">@ViewBag.Error</div>
                }
                <form asp-action="Login" method="post">
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    
                    <div class="form-group mb-3">
                        <label class="fw-bold mb-1 text-secondary">Tài khoản</label>
                        <input type="text" name="username" class="form-control form-control-lg" required autofocus />
                    </div>
                    
                    <div class="form-group mb-4">
                        <label class="fw-bold mb-1 text-secondary">Mật khẩu</label>
                        <input type="password" name="password" class="form-control form-control-lg" required />
                    </div>
                    
                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2 fs-5 shadow-sm">Bảo Lệnh Đăng Nhập</button>
                </form>
            </div>
        </div>
        <p class="text-center text-muted mt-3 small">Bản quyền thuộc về hệ thống TourMap Admin</p>
    </div>
</div>
