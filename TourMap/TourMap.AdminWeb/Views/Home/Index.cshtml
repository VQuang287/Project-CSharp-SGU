@model TourMap.AdminWeb.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Bảng Điều Khiển";
}

<section class="dashboard-grid">
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Tổng POI</p>
            <p class="metric-value">@Model.TotalPois</p>
        </div>
    </article>
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Tour đang hoạt động</p>
            <p class="metric-value">@Model.ActiveTours</p>
        </div>
    </article>
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Tổng lượt phát</p>
            <p class="metric-value">@Model.TotalPlays.ToString("N0")</p>
        </div>
    </article>
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Người dùng Mobile</p>
            <p class="metric-value">@Model.ActiveMobileUsers</p>
        </div>
    </article>
</section>

<section class="dashboard-section ui-card">
    <div class="ui-card-body">
        <h2 class="h6 mb-3">Top POI theo lượt phát</h2>
        <table class="dashboard-table">
            <thead>
                <tr>
                    <th>POI</th>
                    <th>Lượt phát</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.TopPois.Count == 0)
                {
                    <tr>
                        <td colspan="2">Chưa có dữ liệu playback.</td>
                    </tr>
                }
                else
                {
                    @foreach (var poi in Model.TopPois)
                    {
                        <tr>
                            <td>@poi.PoiTitle</td>
                            <td>@poi.PlayCount.ToString("N0")</td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</section>

<section class="dashboard-section ui-card">
    <div class="ui-card-body">
        <h2 class="h6 mb-3">Thao Tác Nhanh</h2>
        <div class="dashboard-form-grid">
            <div>
                <label class="form-label">Tên POI</label>
                <input class="form-control" placeholder="Nhập tên POI" />
            </div>
            <div>
                <label class="form-label">Bán kính (m)</label>
                <input class="form-control" type="number" placeholder="50" />
            </div>
            <div class="full">
                <label class="form-label">Mô tả ngắn</label>
                <textarea class="form-control" rows="3" placeholder="Mô tả cho POI"></textarea>
            </div>
            <div class="full">
                <button class="btn btn-primary">Lưu nháp</button>
            </div>
        </div>
    </div>
</section>
