@model TourMap.AdminWeb.Models.ViewModels.AdminDashboardViewModel
@{
    ViewData["Title"] = "Bảng Điều Khiển";
}

<section class="dashboard-grid">
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Tổng POI</p>
            <p class="metric-value">@Model.TotalPois</p>
        </div>
    </article>
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Tour đang hoạt động</p>
            <p class="metric-value">@Model.ActiveTours</p>
        </div>
    </article>
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Tổng lượt phát</p>
            <p class="metric-value">@Model.TotalPlays.ToString("N0")</p>
        </div>
    </article>
    <article class="ui-card">
        <div class="ui-card-body">
            <p class="metric-title">Thời gian nghe TB</p>
            <p class="metric-value">@Model.AvgListeningTime.ToString("mm\\:ss")</p>
        </div>
    </article>
    <article class="ui-card ui-card--highlight">
        <div class="ui-card-body">
            <p class="metric-title">🔴 Thiết bị đang online</p>
            <p class="metric-value" id="online-devices-count">@Model.OnlineDevices</p>
            <p class="metric-subtitle" id="online-devices-status">Đang cập nhật real-time...</p>
        </div>
    </article>
</section>

<!-- Real-time Device Tracking Panel -->
<section class="dashboard-section ui-card">
    <div class="ui-card-body">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h6 mb-0">Thiết Bị Đang Kết Nối <span class="badge bg-success" id="live-badge">LIVE</span></h2>
        </div>
        <div id="device-list-container">
            <table class="dashboard-table" id="connected-devices-table">
                <thead>
                    <tr>
                        <th>Thiết bị</th>
                        <th>Người dùng</th>
                        <th>Trạng thái</th>
                        <th>Vị trí hiện tại</th>
                        <th>Thời gian kết nối</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody id="device-list">
                    <tr>
                        <td colspan="6" class="text-center text-muted">Đang tải danh sách thiết bị...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</section>

<section class="dashboard-section ui-card">
    <div class="ui-card-body">
        <h2 class="h6 mb-3">Top POI theo lượt phát</h2>
        @if (Model.TopPois.Count == 0)
        {
            <p class="text-muted">Chưa có dữ liệu playback.</p>
        }
        else
        {
            <div style="max-width: 400px; margin: 0 auto;">
                <canvas id="topPoisChart"></canvas>
            </div>
        }
    </div>
</section>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.1/dist/chart.umd.min.js"></script>
    <script>
        // Real-time device tracking
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/hubs/devices")
            .withAutomaticReconnect()
            .build();

        let deviceList = [];

        // Handle device list from server
        connection.on("DeviceList", (devices) => {
            deviceList = devices;
            updateDeviceList();
            updateOnlineCount(devices.length);
        });

        // Handle new device connection
        connection.on("DeviceConnected", (device) => {
            console.log("Device connected:", device);
            // Remove if exists, then add
            deviceList = deviceList.filter(d => d.deviceId !== device.deviceId);
            deviceList.push(device);
            updateDeviceList();
            updateOnlineCount(deviceList.length);
        });

        // Handle device updates
        connection.on("DeviceUpdated", (device) => {
            const index = deviceList.findIndex(d => d.deviceId === device.deviceId);
            if (index !== -1) {
                deviceList[index] = device;
            } else {
                deviceList.push(device);
            }
            updateDeviceList();
        });

        // Handle device disconnection
        connection.on("DeviceDisconnected", (deviceId) => {
            deviceList = deviceList.filter(d => d.deviceId !== deviceId);
            updateDeviceList();
            updateOnlineCount(deviceList.length);
        });

        function updateOnlineCount(count) {
            document.getElementById('online-devices-count').textContent = count;
            // Cập nhật cả navbar badge
            const navBadge = document.getElementById('navbar-device-count');
            if (navBadge) navBadge.textContent = count;
            
            const status = document.getElementById('online-devices-status');
            if (count === 0) {
                status.textContent = 'Không có thiết bị nào đang kết nối';
                status.className = 'metric-subtitle text-muted';
            } else {
                status.textContent = `Cập nhật lúc ${new Date().toLocaleTimeString('vi-VN')}`;
                status.className = 'metric-subtitle text-success';
            }
        }

        function updateDeviceList() {
            const tbody = document.getElementById('device-list');
            
            if (deviceList.length === 0) {
                tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted">Không có thiết bị nào đang kết nối</td></tr>';
                return;
            }

            tbody.innerHTML = deviceList.map(device => {
                const stateBadge = getStateBadge(device.state);
                const location = device.lastLatitude && device.lastLongitude 
                    ? `${device.lastLatitude.toFixed(4)}, ${device.lastLongitude.toFixed(4)}`
                    : 'Không xác định';
                const connectedTime = new Date(device.connectedAt).toLocaleString('vi-VN');
                
                return `
                    <tr data-device-id="${device.deviceId}">
                        <td>
                            <strong>${escapeHtml(device.deviceId.substring(0, 8))}...</strong><br>
                            <small class="text-muted">${escapeHtml(device.deviceType || 'Unknown')}</small>
                        </td>
                        <td>${escapeHtml(device.userName || 'Guest')}</td>
                        <td>${stateBadge}</td>
                        <td>
                            ${location}
                            ${device.currentPoiName ? `<br><small class="text-success">📍 ${escapeHtml(device.currentPoiName)}</small>` : ''}
                        </td>
                        <td>${connectedTime}</td>
                        <td>
                            <button class="btn btn-sm btn-outline-warning" onclick="revokeDevice('${device.deviceId}')" title="Revoke token & kick device">
                                ⛔ Kick
                            </button>
                        </td>
                    </tr>
                `;
            }).join('');
        }

        async function revokeDevice(deviceId) {
            if (!confirm(`Revoke token cho thiết bị ${deviceId.substring(0, 8)}...?\nThiết bị sẽ phải đăng nhập lại.`)) return;
            try {
                const resp = await fetch(`/api/v1/auth/admin/revoke-device/${deviceId}`, { method: 'POST' });
                const data = await resp.json();
                alert(data.message || 'Đã revoke.');
                // Refresh device list
                await connection.invoke("RefreshDeviceList");
            } catch (e) {
                alert('Lỗi: ' + e.message);
            }
        }

        function getStateBadge(state) {
            const badges = {
                0: '<span class="badge bg-success">Online</span>',
                1: '<span class="badge bg-secondary">Idle</span>',
                2: '<span class="badge bg-primary">Playing</span>',
                3: '<span class="badge bg-danger">Offline</span>'
            };
            return badges[state] || `<span class="badge bg-secondary">${state}</span>`;
        }

        function escapeHtml(text) {
            if (!text) return '';
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        // Start connection and join admin group
        let refreshInterval = null;

        async function start() {
            try {
                await connection.start();
                console.log("SignalR Connected.");
                await connection.invoke("JoinAdminGroup");
                document.getElementById('live-badge').textContent = 'LIVE';
                document.getElementById('live-badge').classList.remove('bg-secondary');
                document.getElementById('live-badge').classList.add('bg-success');

                // Auto-refresh danh sách thiết bị mỗi 10 giây
                if (refreshInterval) clearInterval(refreshInterval);
                refreshInterval = setInterval(async () => {
                    try {
                        await connection.invoke("RefreshDeviceList");
                    } catch (e) {
                        console.warn("Refresh failed:", e.message);
                    }
                }, 10000);
            } catch (err) {
                console.error("SignalR Connection Error:", err);
                document.getElementById('live-badge').textContent = 'DISCONNECTED';
                document.getElementById('live-badge').classList.remove('bg-success');
                document.getElementById('live-badge').classList.add('bg-secondary');
                setTimeout(start, 5000);
            }
        }

        connection.onreconnecting(() => {
            console.log("SignalR Reconnecting...");
            document.getElementById('live-badge').textContent = 'RECONNECTING';
            document.getElementById('live-badge').classList.remove('bg-success');
            document.getElementById('live-badge').classList.add('bg-warning');
            if (refreshInterval) { clearInterval(refreshInterval); refreshInterval = null; }
        });

        connection.onreconnected(() => {
            console.log("SignalR Reconnected.");
            document.getElementById('live-badge').textContent = 'LIVE';
            document.getElementById('live-badge').classList.remove('bg-warning');
            document.getElementById('live-badge').classList.add('bg-success');
            connection.invoke("JoinAdminGroup");
            // Khôi phục auto-refresh
            if (refreshInterval) clearInterval(refreshInterval);
            refreshInterval = setInterval(async () => {
                try {
                    await connection.invoke("RefreshDeviceList");
                } catch (e) {
                    console.warn("Refresh failed:", e.message);
                }
            }, 10000);
        });

        // Initialize Top POIs Pie Chart
        @if (Model.TopPois.Count > 0)
        {
            <text>
            const topPoisData = {
                labels: @Html.Raw(Json.Serialize(Model.TopPois.Select(x => x.PoiTitle))),
                datasets: [{
                    data: @Html.Raw(Json.Serialize(Model.TopPois.Select(x => x.PlayCount))),
                    backgroundColor: [
                        '#0d6efd',
                        '#198754',
                        '#ffc107',
                        '#dc3545',
                        '#6c757d'
                    ],
                    borderWidth: 2,
                    borderColor: '#fff'
                }]
            };

            new Chart(document.getElementById('topPoisChart'), {
                type: 'pie',
                data: topPoisData,
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                padding: 15,
                                font: { size: 12 }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    const label = context.label || '';
                                    const value = context.parsed;
                                    const total = context.dataset.data.reduce((a, b) => a + b, 0);
                                    const percentage = ((value / total) * 100).toFixed(1);
                                    return `${label}: ${value.toLocaleString()} lượt (${percentage}%)`;
                                }
                            }
                        }
                    }
                }
            });
            </text>
        }

        start();
    </script>
}
