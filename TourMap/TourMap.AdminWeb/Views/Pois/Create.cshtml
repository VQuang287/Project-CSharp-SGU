@model TourMap.AdminWeb.Models.Poi

@{
    ViewData["Title"] = "Thêm Điểm Mới";
}

<div class="container mt-4">
    <h2 class="text-primary fw-bold">Thêm Điểm Âm Thanh Mới</h2>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Create" class="card shadow p-4 border-0" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                
                <div class="form-group mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tên địa điểm</label>
                    <input asp-for="Title" class="form-control form-control-lg" placeholder="VD: Quán Ốc Oanh" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Văn bản Thuyết Minh (Scripts TTS)</label>
                    <textarea asp-for="Description" class="form-control" rows="4" placeholder="Nếu không up file Audio, App sẽ lấy Text này đọc bằng giọng AI tự động."></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                    
                    <div class="form-check mt-3 border p-2 rounded bg-light">
                        <input type="checkbox" name="autoAI" value="true" class="form-check-input" id="autoAI_check" checked />
                        <label class="form-check-label text-success fw-bold" for="autoAI_check">
                            🤖 Đọc thông qua AI (Tự động Dịch & Tạo Audio Đa ngôn ngữ)
                        </label>
                        <small class="d-block text-muted">Hệ thống sẽ dùng AI dịch nội dung sang Tiếng Anh, Tiếng Trung, Tiếng Hàn và tạo sẵn 3 file Audio (hoàn toàn tự động).</small>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="MapLink" class="form-label fw-bold">Link bản đồ Google Maps (Tuỳ chọn)</label>
                    <input asp-for="MapLink" class="form-control" placeholder="VD: https://maps.app.goo.gl/..." />
                </div>
                
                <div class="row border p-3 rounded bg-light mb-4 mx-0">
                    <h5 class="fw-bold mb-3 text-secondary">Tải lên Đa phương tiện</h5>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Ảnh minh họa (.jpg, .png)</label>
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">File Audio Thu sẵn (.mp3, .wav)</label>
                        <input type="file" name="AudioFile" class="form-control" accept="audio/*" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col">
                        <label asp-for="Latitude" class="form-label fw-bold">Vĩ độ (Latitude)</label>
                        <input asp-for="Latitude" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="Longitude" class="form-label fw-bold">Kinh độ (Longitude)</label>
                        <input asp-for="Longitude" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="RadiusMeters" class="form-label fw-bold">Bán kính quét (m)</label>
                        <input asp-for="RadiusMeters" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="Priority" class="form-label fw-bold">Ưu tiên (1-10)</label>
                        <input asp-for="Priority" class="form-control" />
                    </div>
                </div>
                
                <div class="form-group d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2">Trở về</a>
                    <input type="submit" value="Lưu Tuyến Điểm" class="btn btn-primary shadow px-4 py-2 fw-bold" />
                </div>
            </form>
        </div>
    </div>
</div>
