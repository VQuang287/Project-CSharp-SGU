@model TourMap.AdminWeb.Models.Poi

@{
    ViewData["Title"] = "Xóa Điểm";
}

<div class="container mt-4">
    <h2>Xóa Địa Điểm</h2>
    <h5 class="text-danger">Cảnh báo: Việc xóa dữ liệu này không thể trực tiếp hoàn tác!</h5>
    <hr />
    <div class="card shadow-sm p-4 col-md-8">
        <dl class="row mb-0">
            <dt class="col-sm-3 fw-bold">Tên địa điểm</dt>
            <dd class="col-sm-9 text-primary fw-bold">@Html.DisplayFor(model => model.Title)</dd>
            
            <dt class="col-sm-3 fw-bold">Mô tả</dt>
            <dd class="col-sm-9 text-muted d-block text-truncate" style="max-height: 100px;">@Html.DisplayFor(model => model.Description)</dd>
            
            <dt class="col-sm-3 fw-bold">Vị trí (GPS)</dt>
            <dd class="col-sm-9">@Html.DisplayFor(model => model.Latitude), @Html.DisplayFor(model => model.Longitude)</dd>
        </dl>
        
        <form asp-action="Delete" method="post" class="mt-4 border-top pt-3 d-flex gap-2 justify-content-end">
            <input type="hidden" asp-for="Id" />
            <a asp-action="Index" class="btn btn-secondary">Hủy bỏ quay lại</a>
            <input type="submit" value="Xác Nhận Xóa" class="btn btn-danger shadow" /> 
        </form>
    </div>
</div>
