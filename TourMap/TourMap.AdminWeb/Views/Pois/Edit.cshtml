@model TourMap.AdminWeb.Models.Poi

<style>
    .poi-edit-container {
        max-width: 100%;
        width: 100%;
        margin: 0 auto;
        padding: 0 1rem;
    }

    @@media (min-width: 576px) {
        .poi-edit-container {
            max-width: 540px;
        }
    }

    @@media (min-width: 768px) {
        .poi-edit-container {
            max-width: 720px;
        }
    }

    @@media (min-width: 992px) {
        .poi-edit-container {
            max-width: 900px;
        }
    }

    @@media (min-width: 1200px) {
        .poi-edit-container {
            max-width: 1000px;
        }
    }

    .poi-card {
        border: none;
        border-radius: 12px;
        box-shadow: 0 4px 20px rgba(0,0,0,0.08);
    }

    .section-title {
        font-size: 0.85rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #6c757d;
        margin-bottom: 1rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid #e9ecef;
    }

    .lang-tabs {
        border-bottom: 2px solid #e9ecef;
        margin-bottom: 1rem;
        flex-wrap: nowrap;
        overflow-x: auto;
        overflow-y: hidden;
        -webkit-overflow-scrolling: touch;
        scrollbar-width: thin;
    }

    .lang-tabs::-webkit-scrollbar {
        height: 4px;
    }

    .lang-tabs::-webkit-scrollbar-track {
        background: #f1f1f1;
    }

    .lang-tabs::-webkit-scrollbar-thumb {
        background: #ccc;
        border-radius: 2px;
    }

    .lang-tabs .nav-item {
        flex-shrink: 0;
    }

    .lang-tabs .nav-link {
        border: none;
        border-bottom: 2px solid transparent;
        color: #6c757d;
        font-weight: 500;
        padding: 0.75rem 1rem;
        transition: all 0.2s;
        white-space: nowrap;
    }

    .lang-tabs .nav-link:hover {
        color: #495057;
        border-bottom-color: #dee2e6;
    }

    .lang-tabs .nav-link.active {
        color: #0d6efd;
        border-bottom-color: #0d6efd;
        background: none;
    }

    @@media (max-width: 576px) {
        .lang-tabs .nav-link {
            padding: 0.5rem 0.75rem;
            font-size: 0.875rem;
        }

        .lang-tabs .lang-flag {
            font-size: 1rem;
        }
    }

    .lang-card {
        background: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        margin-bottom: 1rem;
    }

    @@media (max-width: 576px) {
        .lang-card {
            padding: 0.75rem;
        }
    }

    .lang-header {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-weight: 600;
        margin-bottom: 0.75rem;
        color: #495057;
    }

    .lang-flag {
        font-size: 1.25rem;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.5rem 1rem;
        font-size: 0.875rem;
        font-weight: 500;
        border-radius: 6px;
        transition: all 0.2s;
    }

    @@media (max-width: 576px) {
        .btn-action {
            padding: 0.375rem 0.75rem;
            font-size: 0.8125rem;
        }
    }

    .btn-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(0,0,0,0.1);
    }

    .form-section {
        background: #fff;
        border-radius: 8px;
        padding: 1.25rem;
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 576px) {
        .form-section {
            padding: 1rem;
            margin-bottom: 1rem;
        }
    }

    .coords-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 1rem;
    }

    @@media (min-width: 576px) {
        .coords-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @@media (min-width: 992px) {
        .coords-grid {
            grid-template-columns: repeat(4, 1fr);
        }
    }

    .audio-player {
        height: 36px;
        border-radius: 6px;
    }

    .main-actions {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
    }

    @@media (max-width: 576px) {
        .main-actions {
            flex-direction: column;
        }

        .main-actions .btn {
            width: 100%;
            justify-content: center;
        }
    }

    .btn-group-sm .btn {
        padding: 0.375rem 0.75rem;
        font-size: 0.8125rem;
    }

    /* Responsive image container */
    .img-container {
        position: relative;
        width: 100%;
        padding-top: 75%; /* 4:3 aspect ratio */
        overflow: hidden;
        border-radius: 8px;
    }

    .img-container img {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* Responsive textarea */
    textarea.form-control {
        min-height: 100px;
        resize: vertical;
    }

    @@media (max-width: 576px) {
        textarea.form-control {
            min-height: 80px;
        }
    }
</style>

@{
    ViewData["Title"] = "Chỉnh sửa Điểm";
    var viScript = Model.TtsScriptVi ?? Model.Description ?? string.Empty;
    var scriptEn = Model.TtsScriptEn ?? Model.DescriptionEn ?? string.Empty;
    var scriptZh = Model.TtsScriptZh ?? Model.DescriptionZh ?? string.Empty;
    var scriptKo = Model.TtsScriptKo ?? Model.DescriptionKo ?? string.Empty;
    var scriptJa = Model.TtsScriptJa ?? Model.DescriptionJa ?? string.Empty;
    var scriptFr = Model.TtsScriptFr ?? Model.DescriptionFr ?? string.Empty;
    var hasTranslatedScripts =
        !string.IsNullOrWhiteSpace(scriptEn) ||
        !string.IsNullOrWhiteSpace(scriptZh) ||
        !string.IsNullOrWhiteSpace(scriptKo) ||
        !string.IsNullOrWhiteSpace(scriptJa) ||
        !string.IsNullOrWhiteSpace(scriptFr);
}

<div class="poi-edit-container mt-4">
    <div class="d-flex align-items-center gap-3 mb-4">
        <div class="bg-warning bg-opacity-10 p-3 rounded-circle">
            <i class="bi bi-geo-alt-fill text-warning fs-4"></i>
        </div>
        <div>
            <h2 class="fw-bold mb-0">Chỉnh Sửa Địa Điểm</h2>
            <p class="text-muted mb-0">@Model.Title</p>
        </div>
    </div>

    <form asp-action="Edit" method="post" id="poiEditForm" class="poi-card card" enctype="multipart/form-data">
        <div class="card-body p-4">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
            <input type="hidden" asp-for="Id" />
            
            <!-- Thông tin cơ bản -->
            <div class="form-section">
                <div class="section-title">Thông tin cơ bản</div>
                <div class="mb-3">
                    <label asp-for="Title" class="form-label fw-medium">Tên địa điểm</label>
                    <input asp-for="Title" class="form-control form-control-lg" placeholder="Nhập tên địa điểm..." />
                    <span asp-validation-for="Title" class="text-danger small"></span>
                </div>
            </div>

            <!-- Hình ảnh POI -->
            <div class="form-section">
                <div class="section-title">Hình ảnh</div>
                <div class="row align-items-center">
                    <div class="col-md-4 mb-3 mb-md-0">
                        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                        {
                            <div class="img-container">
                                <img src="@Model.ImageUrl" alt="POI Image" class="img-fluid" />
                                <div class="position-absolute top-0 end-0 m-2">
                                    <span class="badge bg-success">Đã có ảnh</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="img-container bg-light d-flex align-items-center justify-content-center">
                                <div class="text-center text-muted">
                                    <i class="bi bi-image fs-1"></i>
                                    <p class="mb-0 small">Chưa có ảnh</p>
                                </div>
                            </div>
                        }
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-medium">Cập nhật hình ảnh</label>
                        <div class="input-group">
                            <input type="file" name="ImageFile" id="ImageFile" class="form-control" accept="image/*" />
                        </div>
                        <div class="form-text text-muted">
                            <i class="bi bi-info-circle"></i> Chọn ảnh mới để thay thế ảnh hiện tại. Hỗ trợ JPG, PNG, WebP.
                        </div>
                        @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
                        {
                            <div class="mt-2">
                                <small class="text-muted">Ảnh hiện tại: <a href="@Model.ImageUrl" target="_blank" class="text-decoration-none">@Model.ImageUrl</a></small>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Scripts đa ngôn ngữ -->
            <div class="form-section">
                <div class="section-title d-flex justify-content-between align-items-center">
                    <span>Scripts Thuyết Minh (TTS)</span>
                    <button type="button" id="btnTranslateScripts" class="btn btn-warning btn-sm btn-action">
                        <i class="bi bi-translate"></i> Dịch tất cả
                    </button>
                </div>

                <!-- Tabs ngôn ngữ -->
                <ul class="nav nav-tabs lang-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-vi" type="button">
                            <span class="lang-flag">🇻🇳</span> Tiếng Việt
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-en" type="button">
                            <span class="lang-flag">🇬🇧</span> English
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-zh" type="button">
                            <span class="lang-flag">🇨🇳</span> 中文
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-ko" type="button">
                            <span class="lang-flag">🇰🇷</span> 한국어
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-ja" type="button">
                            <span class="lang-flag">🇯🇵</span> 日本語
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-fr" type="button">
                            <span class="lang-flag">🇫🇷</span> Français
                        </button>
                    </li>
                </ul>

                <!-- Tab content -->
                <div class="tab-content">
                    <!-- Vietnamese -->
                    <div class="tab-pane fade show active" id="tab-vi">
                        <div class="lang-card">
                            <div class="lang-header">
                                <span class="lang-flag">🇻🇳</span>
                                <span>Tiếng Việt (Mặc định)</span>
                            </div>
                            <textarea id="Description" name="Description" class="form-control mb-3" rows="4" placeholder="Nhập nội dung thuyết minh tiếng Việt...">@viScript</textarea>
                            <div class="d-flex gap-2">
                                <button type="button" id="btnSaveViScript" class="btn btn-success btn-action">
                                    <i class="bi bi-save"></i> Lưu VI
                                </button>
                                <button type="button" id="btnPreviewViScript" class="btn btn-outline-primary btn-action">
                                    <i class="bi bi-play-fill"></i> Nghe thử
                                </button>
                            </div>
                            <audio id="audioViPreview" class="w-100 mt-3 d-none audio-player" controls></audio>
                        </div>
                    </div>

                    <!-- English -->
                    <div class="tab-pane fade" id="tab-en">
                        <div class="lang-card">
                            <div class="lang-header">
                                <span class="lang-flag">🇬🇧</span>
                                <span>English</span>
                            </div>
                            <textarea id="lang-script-en" class="form-control mb-3" rows="4" placeholder="English script...">@scriptEn</textarea>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-success btn-action btn-save-lang" data-lang="en">
                                    <i class="bi bi-save"></i> Lưu EN
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-action btn-preview-lang" data-lang="en">
                                    <i class="bi bi-play-fill"></i> Nghe thử
                                </button>
                            </div>
                            <audio id="lang-audio-en" class="w-100 mt-3 audio-player @(string.IsNullOrWhiteSpace(Model.AudioUrlEn) ? "d-none" : "")" controls src="@Model.AudioUrlEn"></audio>
                        </div>
                    </div>

                    <!-- Chinese -->
                    <div class="tab-pane fade" id="tab-zh">
                        <div class="lang-card">
                            <div class="lang-header">
                                <span class="lang-flag">🇨🇳</span>
                                <span>Chinese (中文)</span>
                            </div>
                            <textarea id="lang-script-zh" class="form-control mb-3" rows="4" placeholder="中文脚本...">@scriptZh</textarea>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-success btn-action btn-save-lang" data-lang="zh">
                                    <i class="bi bi-save"></i> Lưu ZH
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-action btn-preview-lang" data-lang="zh">
                                    <i class="bi bi-play-fill"></i> Nghe thử
                                </button>
                            </div>
                            <audio id="lang-audio-zh" class="w-100 mt-3 audio-player @(string.IsNullOrWhiteSpace(Model.AudioUrlZh) ? "d-none" : "")" controls src="@Model.AudioUrlZh"></audio>
                        </div>
                    </div>

                    <!-- Korean -->
                    <div class="tab-pane fade" id="tab-ko">
                        <div class="lang-card">
                            <div class="lang-header">
                                <span class="lang-flag">🇰🇷</span>
                                <span>Korean (한국어)</span>
                            </div>
                            <textarea id="lang-script-ko" class="form-control mb-3" rows="4" placeholder="한국어 스크립트...">@scriptKo</textarea>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-success btn-action btn-save-lang" data-lang="ko">
                                    <i class="bi bi-save"></i> Lưu KO
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-action btn-preview-lang" data-lang="ko">
                                    <i class="bi bi-play-fill"></i> Nghe thử
                                </button>
                            </div>
                            <audio id="lang-audio-ko" class="w-100 mt-3 audio-player @(string.IsNullOrWhiteSpace(Model.AudioUrlKo) ? "d-none" : "")" controls src="@Model.AudioUrlKo"></audio>
                        </div>
                    </div>

                    <!-- Japanese -->
                    <div class="tab-pane fade" id="tab-ja">
                        <div class="lang-card">
                            <div class="lang-header">
                                <span class="lang-flag">🇯🇵</span>
                                <span>Japanese (日本語)</span>
                            </div>
                            <textarea id="lang-script-ja" class="form-control mb-3" rows="4" placeholder="日本語スクリプト...">@scriptJa</textarea>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-success btn-action btn-save-lang" data-lang="ja">
                                    <i class="bi bi-save"></i> Lưu JA
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-action btn-preview-lang" data-lang="ja">
                                    <i class="bi bi-play-fill"></i> Nghe thử
                                </button>
                            </div>
                            <audio id="lang-audio-ja" class="w-100 mt-3 audio-player @(string.IsNullOrWhiteSpace(Model.AudioUrlJa) ? "d-none" : "")" controls src="@Model.AudioUrlJa"></audio>
                        </div>
                    </div>

                    <!-- French -->
                    <div class="tab-pane fade" id="tab-fr">
                        <div class="lang-card">
                            <div class="lang-header">
                                <span class="lang-flag">🇫🇷</span>
                                <span>French (Français)</span>
                            </div>
                            <textarea id="lang-script-fr" class="form-control mb-3" rows="4" placeholder="Script français...">@scriptFr</textarea>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-success btn-action btn-save-lang" data-lang="fr">
                                    <i class="bi bi-save"></i> Lưu FR
                                </button>
                                <button type="button" class="btn btn-outline-primary btn-action btn-preview-lang" data-lang="fr">
                                    <i class="bi bi-play-fill"></i> Nghe thử
                                </button>
                            </div>
                            <audio id="lang-audio-fr" class="w-100 mt-3 audio-player @(string.IsNullOrWhiteSpace(Model.AudioUrlFr) ? "d-none" : "")" controls src="@Model.AudioUrlFr"></audio>
                        </div>
                    </div>
                </div>

                <div class="d-flex justify-content-end mt-3">
                    <button type="button" id="btnSaveAllFromVi" class="btn btn-danger btn-action">
                        <i class="bi bi-save-fill"></i> Lưu Tất Cả 6 Ngôn Ngữ
                    </button>
                </div>
            </div>

            <!-- Tọa độ -->
            <div class="form-section">
                <div class="section-title">Vị trí & Cấu hình</div>
                <div class="coords-grid">
                    <div>
                        <label asp-for="Latitude" class="form-label small fw-medium text-muted">Vĩ độ</label>
                        <input name="Latitude" id="Latitude" class="form-control" type="text" inputmode="decimal" placeholder="10.7608247" value="@Model.Latitude.ToString().Replace(".", ",")" />
                    </div>
                    <div>
                        <label asp-for="Longitude" class="form-label small fw-medium text-muted">Kinh độ</label>
                        <input name="Longitude" id="Longitude" class="form-control" type="text" inputmode="decimal" placeholder="106.7034143" value="@Model.Longitude.ToString().Replace(".", ",")" />
                    </div>
                    <div>
                        <label asp-for="RadiusMeters" class="form-label small fw-medium text-muted">Bán kính (m)</label>
                        <input asp-for="RadiusMeters" class="form-control" type="number" min="1" max="10000" />
                    </div>
                    <div>
                        <label asp-for="Priority" class="form-label small fw-medium text-muted">Ưu tiên</label>
                        <input asp-for="Priority" class="form-control" type="number" />
                    </div>
                </div>
            </div>

            <!-- Footer Actions -->
            <div class="d-flex justify-content-between align-items-center pt-3 border-top">
                <a asp-action="Index" class="btn btn-outline-secondary btn-action">
                    <i class="bi bi-arrow-left"></i> Quay lại
                </a>
                <button type="submit" id="btnSubmitPoiEdit" class="btn btn-success btn-lg btn-action px-4">
                    <i class="bi bi-check-lg"></i> Lưu Chỉnh Sửa
                </button>
            </div>

            <!-- Modal Popup cho thông báo -->
            <div class="modal fade" id="messageModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header" id="modalHeader">
                            <h5 class="modal-title" id="modalTitle">Thông báo</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body" id="modalBody">
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-primary" data-bs-dismiss="modal">Đóng</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal Xác nhận -->
            <div class="modal fade" id="confirmModal" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header bg-warning">
                            <h5 class="modal-title" id="confirmModalTitle">Xác nhận</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body" id="confirmModalBody">
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                            <button type="button" class="btn btn-primary" id="confirmModalOk">OK</button>
                        </div>
                    </div>
                </div>
            </div>

            <div id="poiEditStatus" class="d-none"></div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const poiId = '@Model.Id';
            const languageLabels = {
                vi: 'Tiếng Việt',
                en: 'English',
                zh: 'Chinese',
                ko: 'Korean',
                ja: 'Japanese',
                fr: 'French'
            };

            const form = document.getElementById('poiEditForm');
            const statusBox = document.getElementById('poiEditStatus');
            const translatedPanel = document.getElementById('translatedScriptsPanel');
            const btnTranslate = document.getElementById('btnTranslateScripts');
            const btnSaveVi = document.getElementById('btnSaveViScript');
            const btnPreviewVi = document.getElementById('btnPreviewViScript');
            const submitBtn = document.getElementById('btnSubmitPoiEdit');
            const defaultSubmitText = submitBtn?.textContent || 'Lưu Chỉnh Sửa';

            const translateUrl = '@Url.Action("TranslateScripts", "Pois")';
            const previewAudioUrl = '@Url.Action("PreviewLanguageAudio", "Pois")';
            const saveLanguageUrl = '@Url.Action("SaveLanguageScript", "Pois")';
            const saveAllScriptsUrl = '@Url.Action("SaveAllScripts", "Pois")';
            let isFormSubmitting = false;
            let submitRecoverTimer = null;
            const messageModal = new bootstrap.Modal(document.getElementById('messageModal'));
            const modalTitle = document.getElementById('modalTitle');
            const modalBody = document.getElementById('modalBody');
            const modalHeader = document.getElementById('modalHeader');
            
            const confirmModal = new bootstrap.Modal(document.getElementById('confirmModal'));
            const confirmModalBody = document.getElementById('confirmModalBody');
            const confirmModalOk = document.getElementById('confirmModalOk');
            let confirmCallback = null;

            function showModal(message, kind = 'info') {
                modalBody.textContent = message;
                modalHeader.className = 'modal-header';
                if (kind === 'success') {
                    modalHeader.classList.add('bg-success', 'text-white');
                    modalTitle.textContent = 'Thành công';
                } else if (kind === 'error') {
                    modalHeader.classList.add('bg-danger', 'text-white');
                    modalTitle.textContent = 'Lỗi';
                } else if (kind === 'warning') {
                    modalHeader.classList.add('bg-warning');
                    modalTitle.textContent = 'Cảnh báo';
                } else {
                    modalHeader.classList.add('bg-info', 'text-white');
                    modalTitle.textContent = 'Thông báo';
                }
                messageModal.show();
            }

            function showStatus(message, kind) {
                // Vẫn giữ lại để tương thích, nhưng chuyển sang modal
                showModal(message, kind);
            }

            function setSubmitLoading(isLoading) {
                if (!submitBtn) {
                    return;
                }

                submitBtn.disabled = isLoading;
                submitBtn.textContent = isLoading ? 'Đang lưu...' : defaultSubmitText;
            }

            function getAntiForgeryToken() {
                return form.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            }

            async function postJson(url, payload) {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: JSON.stringify(payload)
                });

                let data = {};
                try {
                    data = await response.json();
                } catch {
                    data = {};
                }

                if (!response.ok || data.success === false) {
                    const errorMessage = data.message || 'Yêu cầu thất bại.';
                    throw new Error(errorMessage);
                }

                return data;
            }

            function getScriptValue(language) {
                if (language === 'vi') {
                    return document.getElementById('Description').value || '';
                }

                const input = document.getElementById(`lang-script-${language}`);
                return input ? (input.value || '') : '';
            }

            function setScriptValue(language, text) {
                if (language === 'vi') {
                    document.getElementById('Description').value = text || '';
                    return;
                }

                const input = document.getElementById(`lang-script-${language}`);
                if (input) {
                    input.value = text || '';
                }
            }

            async function previewAudio(language, text, audioElementId) {
                if (!text || !text.trim()) {
                    showStatus(`Scripts ${languageLabels[language]} đang trống, không thể nghe lại.`, 'warning');
                    return;
                }

                showStatus(`Đang tạo audio AI cho ${languageLabels[language]}...`, 'secondary');
                const result = await postJson(previewAudioUrl, { language: language, text: text });
                const audioElement = document.getElementById(audioElementId);
                if (!audioElement || !result.audioUrl) {
                    throw new Error('Không nhận được đường dẫn audio.');
                }

                audioElement.src = result.audioUrl;
                audioElement.classList.remove('d-none');
                await audioElement.play();
                showStatus(`Đang phát audio ${languageLabels[language]}.`, 'success');
            }

            async function saveLanguage(language) {
                const text = getScriptValue(language);
                if (!text || !text.trim()) {
                    showStatus(`Scripts ${languageLabels[language]} đang trống, chưa thể lưu.`, 'warning');
                    return;
                }

                showConfirm(`Xác nhận lưu scripts ${languageLabels[language]} vào database?`, async function () {
                    showStatus(`Đang lưu scripts ${languageLabels[language]}...`, 'secondary');
                    const result = await postJson(saveLanguageUrl, {
                        poiId: poiId,
                        language: language,
                        text: text
                    });

                    if (result.audioUrl) {
                        const audioElement = document.getElementById(language === 'vi' ? 'audioViPreview' : `lang-audio-${language}`);
                        if (audioElement) {
                            audioElement.src = result.audioUrl;
                            audioElement.classList.remove('d-none');
                        }
                    }

                    showStatus(`Đã lưu scripts ${languageLabels[language]} vào database.`, 'success');
                });
            }

            btnTranslate.addEventListener('click', async function () {
                const sourceText = document.getElementById('Description').value || '';
                if (!sourceText.trim()) {
                    showModal('Bạn cần nhập Scripts TTS tiếng Việt trước khi dịch.', 'warning');
                    return;
                }

                try {
                    showModal('Đang dịch scripts sang 5 ngôn ngữ...', 'info');
                    const result = await postJson(translateUrl, { sourceText: sourceText });
                    const translations = result.translations || {};

                    ['en', 'zh', 'ko', 'ja', 'fr'].forEach(function (lang) {
                        setScriptValue(lang, translations[lang] || '');
                    });

                    // Chuyển sang tab English để hiển thị kết quả
                    const enTab = document.querySelector('[data-bs-target="#tab-en"]');
                    if (enTab) {
                        const tab = new bootstrap.Tab(enTab);
                        tab.show();
                    }

                    showModal('Đã dịch xong 5 ngôn ngữ. Bạn có thể nghe lại hoặc lưu từng ngôn ngữ.', 'success');
                } catch (error) {
                    showModal(error.message || 'Dịch scripts thất bại.', 'error');
                }
            });

            // Hàm hiển thị modal xác nhận
            function showConfirm(message, onConfirm) {
                confirmModalBody.textContent = message;
                confirmCallback = onConfirm;
                confirmModal.show();
            }
            
            confirmModalOk.addEventListener('click', function () {
                confirmModal.hide();
                if (confirmCallback) {
                    confirmCallback();
                    confirmCallback = null;
                }
            });

            // Lưu tất cả 6 ngôn ngữ cùng lúc
            document.getElementById('btnSaveAllFromVi').addEventListener('click', async function () {
                const viText = document.getElementById('Description').value || '';
                if (!viText.trim()) {
                    showModal('Scripts tiếng Việt đang trống. Vui lòng nhập nội dung trước.', 'warning');
                    return;
                }

                showConfirm('Xác nhận lưu tất cả 6 ngôn ngữ (VI, EN, ZH, KO, JA, FR) vào database?', async function () {
                    showModal('Đang lưu tất cả 6 ngôn ngữ...', 'info');

                    const scripts = {
                        'vi': viText,
                        'en': document.getElementById('lang-script-en')?.value || '',
                        'zh': document.getElementById('lang-script-zh')?.value || '',
                        'ko': document.getElementById('lang-script-ko')?.value || '',
                        'ja': document.getElementById('lang-script-ja')?.value || '',
                        'fr': document.getElementById('lang-script-fr')?.value || ''
                    };

                    try {
                        const result = await postJson(saveAllScriptsUrl, { poiId: poiId, scripts: scripts });
                        showModal(result.message || `Đã lưu ${result.savedCount}/6 scripts thành công!`, 'success');
                    } catch (error) {
                        showModal(error.message || 'Lưu tất cả scripts thất bại.', 'error');
                    }
                });
            });

            btnPreviewVi.addEventListener('click', async function () {
                try {
                    await previewAudio('vi', getScriptValue('vi'), 'audioViPreview');
                } catch (error) {
                    showStatus(error.message || 'Nghe lại audio tiếng Việt thất bại.', 'error');
                }
            });

            btnSaveVi.addEventListener('click', async function () {
                try {
                    await saveLanguage('vi');
                } catch (error) {
                    showStatus(error.message || 'Lưu scripts tiếng Việt thất bại.', 'error');
                }
            });

            document.querySelectorAll('.btn-preview-lang').forEach(function (button) {
                button.addEventListener('click', async function () {
                    const lang = button.dataset.lang;
                    try {
                        await previewAudio(lang, getScriptValue(lang), `lang-audio-${lang}`);
                    } catch (error) {
                        showStatus(error.message || `Nghe lại audio ${languageLabels[lang]} thất bại.`, 'error');
                    }
                });
            });

            document.querySelectorAll('.btn-save-lang').forEach(function (button) {
                button.addEventListener('click', async function () {
                    const lang = button.dataset.lang;
                    try {
                        await saveLanguage(lang);
                    } catch (error) {
                        showStatus(error.message || `Lưu scripts ${languageLabels[lang]} thất bại.`, 'error');
                    }
                });
            });

            let pendingSubmit = false;
            
            form.addEventListener('submit', function (event) {
                if (isFormSubmitting) {
                    event.preventDefault();
                    return;
                }

                // Nếu đã xác nhận từ modal, cho phép submit bình thường
                if (pendingSubmit) {
                    pendingSubmit = false;
                    isFormSubmitting = true;
                    setSubmitLoading(true);
                    
                    if (submitRecoverTimer) {
                        window.clearTimeout(submitRecoverTimer);
                    }
                    submitRecoverTimer = window.setTimeout(function () {
                        if (isFormSubmitting) {
                            isFormSubmitting = false;
                            setSubmitLoading(false);
                            showModal('Lưu đang phản hồi quá lâu. Vui lòng bấm lưu lại hoặc kiểm tra server/database.', 'warning');
                        }
                    }, 25000);
                    return;
                }

                event.preventDefault();

                if (typeof form.checkValidity === 'function' && !form.checkValidity()) {
                    showModal('Một số trường dữ liệu chưa hợp lệ. Vui lòng kiểm tra lại trước khi lưu.', 'warning');
                    if (typeof form.reportValidity === 'function') {
                        form.reportValidity();
                    }
                    return;
                }

                if (window.jQuery && typeof window.jQuery(form).valid === 'function' && !window.jQuery(form).valid()) {
                    showModal('Có dữ liệu chưa hợp lệ nên chưa thể lưu. Vui lòng kiểm tra lại các trường tọa độ/số liệu.', 'warning');
                    return;
                }

                showConfirm('Xác nhận lưu toàn bộ chỉnh sửa của POI này vào database?', function () {
                    pendingSubmit = true;
                    form.submit();
                });
            });

            window.addEventListener('pageshow', function () {
                isFormSubmitting = false;
                setSubmitLoading(false);

                if (submitRecoverTimer) {
                    window.clearTimeout(submitRecoverTimer);
                    submitRecoverTimer = null;
                }
            });
        })();
    </script>
}
