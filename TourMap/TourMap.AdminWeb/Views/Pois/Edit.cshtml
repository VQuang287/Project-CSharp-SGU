@model TourMap.AdminWeb.Models.Poi

@{
    ViewData["Title"] = "Chỉnh sửa Điểm";
    var viScript = Model.TtsScriptVi ?? Model.Description ?? string.Empty;
    var scriptEn = Model.TtsScriptEn ?? Model.DescriptionEn ?? string.Empty;
    var scriptZh = Model.TtsScriptZh ?? Model.DescriptionZh ?? string.Empty;
    var scriptKo = Model.TtsScriptKo ?? Model.DescriptionKo ?? string.Empty;
    var scriptJa = Model.TtsScriptJa ?? Model.DescriptionJa ?? string.Empty;
    var scriptFr = Model.TtsScriptFr ?? Model.DescriptionFr ?? string.Empty;
    var hasTranslatedScripts =
        !string.IsNullOrWhiteSpace(scriptEn) ||
        !string.IsNullOrWhiteSpace(scriptZh) ||
        !string.IsNullOrWhiteSpace(scriptKo) ||
        !string.IsNullOrWhiteSpace(scriptJa) ||
        !string.IsNullOrWhiteSpace(scriptFr);
}

<div class="container mt-4">
    <h2 class="text-warning fw-bold">✏️ Chỉnh Sửa Địa Điểm</h2>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit" method="post" id="poiEditForm" class="card shadow p-4 border-0" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="form-group mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tên địa điểm</label>
                    <input asp-for="Title" class="form-control form-control-lg" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label for="Description" class="form-label fw-bold">Văn bản Thuyết Minh (Scripts TTS)</label>
                    <textarea id="Description" name="Description" class="form-control" rows="4">@viScript</textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>

                    <div class="d-flex flex-wrap gap-2 mt-3">
                        <button type="button" id="btnSaveViScript" class="btn btn-outline-success">💾 Lưu Scripts VI</button>
                        <button type="button" id="btnPreviewViScript" class="btn btn-outline-primary">🔊 Nghe lại</button>
                        <button type="button" id="btnTranslateScripts" class="btn btn-warning fw-bold">🌐 Dịch sang 5 ngôn ngữ</button>
                    </div>

                    <audio id="audioViPreview" class="w-100 mt-2 d-none" controls style="height:35px;"></audio>
                    <small class="d-block text-muted mt-2">Nút Lưu Scripts VI chỉ lưu riêng nội dung tiếng Việt và audio tiếng Việt vào database.</small>
                </div>

                <div id="translatedScriptsPanel" class="mt-3 @(hasTranslatedScripts ? string.Empty : "d-none")">
                    <div class="alert alert-info mb-2">
                        <h5 class="fw-bold mb-1">🌐 Scripts đa ngôn ngữ (5 ngôn ngữ hệ thống)</h5>
                        <small class="text-muted">Các ô bên dưới ở chế độ chỉ đọc. Mỗi ngôn ngữ có nút Nghe lại và Lưu riêng vào database.</small>
                    </div>

                    <div class="border rounded p-3 bg-light mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="fw-bold mb-0">🇬🇧 English (EN)</label>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary btn-preview-lang" data-lang="en">🔊 Nghe lại</button>
                                <button type="button" class="btn btn-sm btn-outline-success btn-save-lang" data-lang="en">💾 Lưu</button>
                            </div>
                        </div>
                        <textarea id="lang-script-en" class="form-control" rows="3" readonly>@scriptEn</textarea>
                        <audio id="lang-audio-en" class="w-100 mt-2 @(string.IsNullOrWhiteSpace(Model.AudioUrlEn) ? "d-none" : string.Empty)" controls src="@Model.AudioUrlEn" style="height:35px;"></audio>
                    </div>

                    <div class="border rounded p-3 bg-light mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="fw-bold mb-0">🇨🇳 Chinese (ZH)</label>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary btn-preview-lang" data-lang="zh">🔊 Nghe lại</button>
                                <button type="button" class="btn btn-sm btn-outline-success btn-save-lang" data-lang="zh">💾 Lưu</button>
                            </div>
                        </div>
                        <textarea id="lang-script-zh" class="form-control" rows="3" readonly>@scriptZh</textarea>
                        <audio id="lang-audio-zh" class="w-100 mt-2 @(string.IsNullOrWhiteSpace(Model.AudioUrlZh) ? "d-none" : string.Empty)" controls src="@Model.AudioUrlZh" style="height:35px;"></audio>
                    </div>

                    <div class="border rounded p-3 bg-light mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="fw-bold mb-0">🇰🇷 Korean (KO)</label>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary btn-preview-lang" data-lang="ko">🔊 Nghe lại</button>
                                <button type="button" class="btn btn-sm btn-outline-success btn-save-lang" data-lang="ko">💾 Lưu</button>
                            </div>
                        </div>
                        <textarea id="lang-script-ko" class="form-control" rows="3" readonly>@scriptKo</textarea>
                        <audio id="lang-audio-ko" class="w-100 mt-2 @(string.IsNullOrWhiteSpace(Model.AudioUrlKo) ? "d-none" : string.Empty)" controls src="@Model.AudioUrlKo" style="height:35px;"></audio>
                    </div>

                    <div class="border rounded p-3 bg-light mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="fw-bold mb-0">🇯🇵 Japanese (JA)</label>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary btn-preview-lang" data-lang="ja">🔊 Nghe lại</button>
                                <button type="button" class="btn btn-sm btn-outline-success btn-save-lang" data-lang="ja">💾 Lưu</button>
                            </div>
                        </div>
                        <textarea id="lang-script-ja" class="form-control" rows="3" readonly>@scriptJa</textarea>
                        <audio id="lang-audio-ja" class="w-100 mt-2 @(string.IsNullOrWhiteSpace(Model.AudioUrlJa) ? "d-none" : string.Empty)" controls src="@Model.AudioUrlJa" style="height:35px;"></audio>
                    </div>

                    <div class="border rounded p-3 bg-light mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="fw-bold mb-0">🇫🇷 French (FR)</label>
                            <div class="d-flex gap-2">
                                <button type="button" class="btn btn-sm btn-outline-primary btn-preview-lang" data-lang="fr">🔊 Nghe lại</button>
                                <button type="button" class="btn btn-sm btn-outline-success btn-save-lang" data-lang="fr">💾 Lưu</button>
                            </div>
                        </div>
                        <textarea id="lang-script-fr" class="form-control" rows="3" readonly>@scriptFr</textarea>
                        <audio id="lang-audio-fr" class="w-100 mt-2 @(string.IsNullOrWhiteSpace(Model.AudioUrlFr) ? "d-none" : string.Empty)" controls src="@Model.AudioUrlFr" style="height:35px;"></audio>
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col">
                        <label asp-for="Latitude" class="form-label fw-bold">Vĩ độ</label>
                        <input asp-for="Latitude" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="Longitude" class="form-label fw-bold">Kinh độ</label>
                        <input asp-for="Longitude" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="RadiusMeters" class="form-label fw-bold">Bán kính (m)</label>
                        <input asp-for="RadiusMeters" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="Priority" class="form-label fw-bold">Ưu tiên</label>
                        <input asp-for="Priority" class="form-control" />
                    </div>
                </div>

                <div id="poiEditStatus" class="alert alert-secondary d-none" role="alert"></div>
                
                <div class="form-group d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2">Trở về</a>
                    <button type="submit" id="btnSubmitPoiEdit" class="btn btn-success shadow px-4 py-2 fw-bold">Lưu Chỉnh Sửa</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const poiId = '@Model.Id';
            const languageLabels = {
                vi: 'Tiếng Việt',
                en: 'English',
                zh: 'Chinese',
                ko: 'Korean',
                ja: 'Japanese',
                fr: 'French'
            };

            const form = document.getElementById('poiEditForm');
            const statusBox = document.getElementById('poiEditStatus');
            const translatedPanel = document.getElementById('translatedScriptsPanel');
            const btnTranslate = document.getElementById('btnTranslateScripts');
            const btnSaveVi = document.getElementById('btnSaveViScript');
            const btnPreviewVi = document.getElementById('btnPreviewViScript');
            const submitBtn = document.getElementById('btnSubmitPoiEdit');
            const defaultSubmitText = submitBtn?.textContent || 'Lưu Chỉnh Sửa';

            const translateUrl = '@Url.Action("TranslateScripts", "Pois")';
            const previewAudioUrl = '@Url.Action("PreviewLanguageAudio", "Pois")';
            const saveLanguageUrl = '@Url.Action("SaveLanguageScript", "Pois")';
            let isFormSubmitting = false;
            let submitRecoverTimer = null;

            function showStatus(message, kind) {
                statusBox.classList.remove('d-none', 'alert-secondary', 'alert-success', 'alert-danger', 'alert-warning');
                statusBox.classList.add(kind === 'success' ? 'alert-success' : kind === 'error' ? 'alert-danger' : kind === 'warning' ? 'alert-warning' : 'alert-secondary');
                statusBox.textContent = message;
            }

            function setSubmitLoading(isLoading) {
                if (!submitBtn) {
                    return;
                }

                submitBtn.disabled = isLoading;
                submitBtn.textContent = isLoading ? 'Đang lưu...' : defaultSubmitText;
            }

            function getAntiForgeryToken() {
                return form.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
            }

            async function postJson(url, payload) {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': getAntiForgeryToken()
                    },
                    body: JSON.stringify(payload)
                });

                let data = {};
                try {
                    data = await response.json();
                } catch {
                    data = {};
                }

                if (!response.ok || data.success === false) {
                    const errorMessage = data.message || 'Yêu cầu thất bại.';
                    throw new Error(errorMessage);
                }

                return data;
            }

            function getScriptValue(language) {
                if (language === 'vi') {
                    return document.getElementById('Description').value || '';
                }

                const input = document.getElementById(`lang-script-${language}`);
                return input ? (input.value || '') : '';
            }

            function setScriptValue(language, text) {
                if (language === 'vi') {
                    document.getElementById('Description').value = text || '';
                    return;
                }

                const input = document.getElementById(`lang-script-${language}`);
                if (input) {
                    input.value = text || '';
                }
            }

            async function previewAudio(language, text, audioElementId) {
                if (!text || !text.trim()) {
                    showStatus(`Scripts ${languageLabels[language]} đang trống, không thể nghe lại.`, 'warning');
                    return;
                }

                showStatus(`Đang tạo audio AI cho ${languageLabels[language]}...`, 'secondary');
                const result = await postJson(previewAudioUrl, { language: language, text: text });
                const audioElement = document.getElementById(audioElementId);
                if (!audioElement || !result.audioUrl) {
                    throw new Error('Không nhận được đường dẫn audio.');
                }

                audioElement.src = result.audioUrl;
                audioElement.classList.remove('d-none');
                await audioElement.play();
                showStatus(`Đang phát audio ${languageLabels[language]}.`, 'success');
            }

            async function saveLanguage(language) {
                const text = getScriptValue(language);
                if (!text || !text.trim()) {
                    showStatus(`Scripts ${languageLabels[language]} đang trống, chưa thể lưu.`, 'warning');
                    return;
                }

                const confirmed = confirm(`Xác nhận lưu scripts ${languageLabels[language]} vào database?`);
                if (!confirmed) {
                    return;
                }

                showStatus(`Đang lưu scripts ${languageLabels[language]}...`, 'secondary');
                const result = await postJson(saveLanguageUrl, {
                    poiId: poiId,
                    language: language,
                    text: text
                });

                if (result.audioUrl) {
                    const audioElement = document.getElementById(language === 'vi' ? 'audioViPreview' : `lang-audio-${language}`);
                    if (audioElement) {
                        audioElement.src = result.audioUrl;
                        audioElement.classList.remove('d-none');
                    }
                }

                showStatus(`Đã lưu scripts ${languageLabels[language]} vào database.`, 'success');
            }

            btnTranslate.addEventListener('click', async function () {
                const sourceText = document.getElementById('Description').value || '';
                if (!sourceText.trim()) {
                    showStatus('Bạn cần nhập Scripts TTS tiếng Việt trước khi dịch.', 'warning');
                    return;
                }

                try {
                    showStatus('Đang dịch scripts sang 5 ngôn ngữ...', 'secondary');
                    const result = await postJson(translateUrl, { sourceText: sourceText });
                    const translations = result.translations || {};

                    ['en', 'zh', 'ko', 'ja', 'fr'].forEach(function (lang) {
                        setScriptValue(lang, translations[lang] || '');
                    });

                    translatedPanel.classList.remove('d-none');
                    showStatus('Đã dịch xong 5 ngôn ngữ. Bạn có thể nghe lại hoặc lưu từng ngôn ngữ.', 'success');
                } catch (error) {
                    showStatus(error.message || 'Dịch scripts thất bại.', 'error');
                }
            });

            btnPreviewVi.addEventListener('click', async function () {
                try {
                    await previewAudio('vi', getScriptValue('vi'), 'audioViPreview');
                } catch (error) {
                    showStatus(error.message || 'Nghe lại audio tiếng Việt thất bại.', 'error');
                }
            });

            btnSaveVi.addEventListener('click', async function () {
                try {
                    await saveLanguage('vi');
                } catch (error) {
                    showStatus(error.message || 'Lưu scripts tiếng Việt thất bại.', 'error');
                }
            });

            document.querySelectorAll('.btn-preview-lang').forEach(function (button) {
                button.addEventListener('click', async function () {
                    const lang = button.dataset.lang;
                    try {
                        await previewAudio(lang, getScriptValue(lang), `lang-audio-${lang}`);
                    } catch (error) {
                        showStatus(error.message || `Nghe lại audio ${languageLabels[lang]} thất bại.`, 'error');
                    }
                });
            });

            document.querySelectorAll('.btn-save-lang').forEach(function (button) {
                button.addEventListener('click', async function () {
                    const lang = button.dataset.lang;
                    try {
                        await saveLanguage(lang);
                    } catch (error) {
                        showStatus(error.message || `Lưu scripts ${languageLabels[lang]} thất bại.`, 'error');
                    }
                });
            });

            form.addEventListener('submit', function (event) {
                if (isFormSubmitting) {
                    event.preventDefault();
                    return;
                }

                if (typeof form.checkValidity === 'function' && !form.checkValidity()) {
                    event.preventDefault();
                    showStatus('Một số trường dữ liệu chưa hợp lệ. Vui lòng kiểm tra lại trước khi lưu.', 'warning');
                    if (typeof form.reportValidity === 'function') {
                        form.reportValidity();
                    }
                    return;
                }

                if (window.jQuery && typeof window.jQuery(form).valid === 'function' && !window.jQuery(form).valid()) {
                    event.preventDefault();
                    showStatus('Có dữ liệu chưa hợp lệ nên chưa thể lưu. Vui lòng kiểm tra lại các trường tọa độ/số liệu.', 'warning');
                    return;
                }

                const confirmed = confirm('Xác nhận lưu toàn bộ chỉnh sửa của POI này vào database?');
                if (!confirmed) {
                    event.preventDefault();
                    return;
                }

                isFormSubmitting = true;
                showStatus('Đang lưu toàn bộ chỉnh sửa POI...', 'secondary');

                if (submitRecoverTimer) {
                    window.clearTimeout(submitRecoverTimer);
                }

                setSubmitLoading(true);

                // If another handler blocks submit or server stalls too long, recover UI state.
                submitRecoverTimer = window.setTimeout(function () {
                    if (!isFormSubmitting) {
                        return;
                    }

                    isFormSubmitting = false;
                    setSubmitLoading(false);
                    showStatus('Lưu đang phản hồi quá lâu. Vui lòng bấm lưu lại hoặc kiểm tra server/database.', 'warning');
                }, 25000);

                // Handle cases where submit is canceled by another handler after this listener.
                window.setTimeout(function () {
                    if (!event.defaultPrevented) {
                        return;
                    }

                    isFormSubmitting = false;
                    setSubmitLoading(false);
                }, 0);
            });

            window.addEventListener('pageshow', function () {
                isFormSubmitting = false;
                setSubmitLoading(false);

                if (submitRecoverTimer) {
                    window.clearTimeout(submitRecoverTimer);
                    submitRecoverTimer = null;
                }
            });
        })();
    </script>
}
