@model TourMap.AdminWeb.Models.Poi

@{
    ViewData["Title"] = "Chỉnh sửa Điểm";
}

<div class="container mt-4">
    <h2 class="text-warning fw-bold">Chỉnh Sửa Địa Điểm</h2>
    <hr />
    <div class="row">
        <div class="col-md-8">
            <form asp-action="Edit" class="card shadow p-4 border-0" enctype="multipart/form-data">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                <input type="hidden" asp-for="Id" />
                
                <div class="form-group mb-3">
                    <label asp-for="Title" class="form-label fw-bold">Tên địa điểm</label>
                    <input asp-for="Title" class="form-control form-control-lg" />
                    <span asp-validation-for="Title" class="text-danger"></span>
                </div>
                
                <div class="form-group mb-3">
                    <label asp-for="Description" class="form-label fw-bold">Văn bản Thuyết Minh (Scripts TTS)</label>
                    <textarea asp-for="Description" class="form-control" rows="4"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>

                    <div class="form-check mt-3 border p-2 rounded bg-light">
                        <input type="checkbox" name="autoAI" value="true" class="form-check-input" id="autoAI_check" />
                        <label class="form-check-label text-success fw-bold" for="autoAI_check">
                            🤖 Đọc thông qua AI (Dịch & Tạo lại Audio Đa ngôn ngữ)
                        </label>
                        <small class="d-block text-muted">Tích vào đây nếu bạn vừa sửa nội dung và muốn AI tự động sinh lại bản dịch/Audio (Tiếng Anh, Trung, Hàn).</small>
                    </div>
                </div>

                @if(!string.IsNullOrEmpty(Model.AudioUrlEn) || !string.IsNullOrEmpty(Model.AudioUrlZh) || !string.IsNullOrEmpty(Model.AudioUrlKo))
                {
                    <div class="alert alert-info mt-3">
                        <h5 class="fw-bold mb-3">🌐 Dữ liệu Đa ngôn ngữ (AI Generated)</h5>
                        
                        @if(!string.IsNullOrEmpty(Model.DescriptionEn)) {
                            <div class="mt-2"><strong>🇬🇧 Tiếng Anh:</strong> <span class="text-muted">@Model.DescriptionEn</span></div>
                            @if(!string.IsNullOrEmpty(Model.AudioUrlEn)) { <audio controls src="@Model.AudioUrlEn" class="w-100 mt-1" style="height:35px;"></audio> }
                        }
                        
                        @if(!string.IsNullOrEmpty(Model.DescriptionZh)) {
                            <div class="mt-3"><strong>🇨🇳 Tiếng Trung:</strong> <span class="text-muted">@Model.DescriptionZh</span></div>
                            @if(!string.IsNullOrEmpty(Model.AudioUrlZh)) { <audio controls src="@Model.AudioUrlZh" class="w-100 mt-1" style="height:35px;"></audio> }
                        }
                        
                        @if(!string.IsNullOrEmpty(Model.DescriptionKo)) {
                            <div class="mt-3"><strong>🇰🇷 Tiếng Hàn:</strong> <span class="text-muted">@Model.DescriptionKo</span></div>
                            @if(!string.IsNullOrEmpty(Model.AudioUrlKo)) { <audio controls src="@Model.AudioUrlKo" class="w-100 mt-1" style="height:35px;"></audio> }
                        }
                    </div>
                }

                <div class="form-group mb-3">
                    <label asp-for="MapLink" class="form-label fw-bold">Link bản đồ Google Maps (Tuỳ chọn)</label>
                    <input asp-for="MapLink" class="form-control" />
                </div>
                
                <div class="row border p-3 rounded bg-light mb-4 mx-0">
                    <h5 class="fw-bold mb-3 text-secondary">Tải lên Thay thế Đa phương tiện</h5>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Ảnh minh họa (Bỏ trống nếu giữ cũ)</label>
                        @if(!string.IsNullOrEmpty(Model.ImageUrl)){ <small class="text-success d-block mb-1">Đã có ảnh.</small> }
                        <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">File Audio Thu sẵn (Bỏ trống nếu giữ cũ)</label>
                        @if(!string.IsNullOrEmpty(Model.AudioUrl)){ <small class="text-success d-block mb-1">Đã có Audio mp3.</small> }
                        <input type="file" name="AudioFile" class="form-control" accept="audio/*" />
                    </div>
                </div>

                <div class="row mb-4">
                    <div class="col">
                        <label asp-for="Latitude" class="form-label fw-bold">Vĩ độ</label>
                        <input asp-for="Latitude" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="Longitude" class="form-label fw-bold">Kinh độ</label>
                        <input asp-for="Longitude" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="RadiusMeters" class="form-label fw-bold">Bán kính quét</label>
                        <input asp-for="RadiusMeters" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="Priority" class="form-label fw-bold">Ưu tiên</label>
                        <input asp-for="Priority" class="form-control" />
                    </div>
                </div>
                
                <div class="form-group d-flex justify-content-end gap-2">
                    <a asp-action="Index" class="btn btn-secondary px-4 py-2">Trở về</a>
                    <input type="submit" value="Lưu Chỉnh Sửa" class="btn btn-success shadow px-4 py-2 fw-bold" />
                </div>
            </form>
        </div>
    </div>
</div>
