@model IEnumerable<TourMap.AdminWeb.Models.Poi>

@{
    ViewData["Title"] = "Quản lý dữ liệu POI";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Kho Dữ Liệu TTS & Audio (POIs)</h1>
    <a asp-action="Create" class="btn btn-primary fw-bold">+ Thêm mới POI</a>
</div>

<div class="d-flex gap-2 mb-3">
    <input type="text" id="searchPoi" class="form-control" placeholder="🔍 Tìm theo tên, mô tả POI..." />
</div>

<div class="card shadow rounded border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 35%;">Ảnh & Tên Địa Điểm</th>
                    <th style="width: 25%;">Tọa độ & Link Map</th>
                    <th style="width: 25%;">Âm thanh (Audio/TTS)</th>
                    <th class="text-center" style="width: 15%;">Hành động</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model) {
                <tr style="height: 100px;">
                    <td class="align-middle" style="vertical-align: middle;">
                        <div class="d-flex align-items-center gap-3">
                            @if(!string.IsNullOrEmpty(item.ImageUrl)){
                                <img src="@item.ImageUrl" alt="Hình ảnh" class="rounded object-fit-cover shadow-sm flex-shrink-0" style="width: 60px; height: 60px;" />
                            } else {
                                <div class="bg-secondary rounded d-flex align-items-center justify-content-center text-white fw-bold shadow-sm flex-shrink-0" style="width: 60px; height: 60px; font-size: 10px;">No IMG</div>
                            }
                            <div class="text-start">
                                <div class="d-flex align-items-center gap-2">
                                    <strong class="text-primary fs-5">@item.Title</strong>
                                    @if (!item.IsActive) { <span class="badge bg-danger">Đã ẩn</span> }
                                </div>
                                <small class="text-muted d-block text-truncate" style="max-width: 200px;">Bán kính: @item.RadiusMeters m | Ưu tiên: Level @item.Priority</small>
                            </div>
                        </div>
                    </td>
                    <td class="align-middle" style="vertical-align: middle;">
                        <div class="text-start">
                            <small class="fw-bold d-block">@item.Latitude</small>
                            <small class="fw-bold d-block">@item.Longitude</small>
                        </div>
                    </td>
                    <td class="align-middle" style="vertical-align: middle;">
                        <div class="text-start">
                            @if(!string.IsNullOrEmpty(item.AudioUrl)){
                                <audio controls class="w-100" style="height: 32px; min-width: 140px;">
                                    <source src="@item.AudioUrl" type="audio/mpeg">
                                </audio>
                            } else {
                                <span class="badge bg-info text-dark shadow-sm">Thuyết minh tự động (TTS)</span>
                                <small class="text-muted d-block text-truncate mt-1" style="max-width: 160px;">@item.Description</small>
                            }
                        </div>
                    </td>
                    <td class="align-middle text-center" style="vertical-align: middle;">
                        <div class="d-flex flex-column gap-1 px-2">
                           <form asp-action="ToggleVisibility" method="post" class="m-0">
                               <input type="hidden" name="id" value="@item.Id" />
                               <button type="submit" class="btn btn-sm @(item.IsActive ? "btn-outline-secondary" : "btn-success") w-100" style="height: 26px; padding: 2px 4px; font-size: 11px;">
                                   @(item.IsActive ? "👁️ Ẩn" : "✓ Hiện")
                               </button>
                           </form>
                           <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning w-100" style="height: 26px; padding: 2px 4px; font-size: 11px;">✏️ Sửa</a>
                           <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger w-100" style="height: 26px; padding: 2px 4px; font-size: 11px;">🗑️ Xóa</a>
                        </div>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
document.getElementById('searchPoi').addEventListener('input', function () {
    var q = this.value.toLowerCase();
    document.querySelectorAll('table tbody tr').forEach(function (row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});
</script>
}
