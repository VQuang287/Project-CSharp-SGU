@model IEnumerable<TourMap.AdminWeb.Models.Poi>

@{
    ViewData["Title"] = "Quản lý dữ liệu POI";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1>Kho Dữ Liệu TTS & Audio (POIs)</h1>
    <a asp-action="Create" class="btn btn-primary fw-bold">+ Thêm mới POI</a>
</div>

<div class="card shadow rounded border-0">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 35%;">Ảnh & Tên Địa Điểm</th>
                    <th style="width: 25%;">Tọa độ & Link Map</th>
                    <th style="width: 25%;">Âm thanh (Audio/TTS)</th>
                    <th class="text-center" style="width: 15%;">Hành động</th>
                </tr>
            </thead>
            <tbody>
        @foreach (var item in Model) {
                <tr>
                    <td class="d-flex align-items-center gap-3">
                        @if(!string.IsNullOrEmpty(item.ImageUrl)){
                            <img src="@item.ImageUrl" alt="Hình ảnh" class="rounded object-fit-cover shadow-sm" style="width: 60px; height: 60px;" />
                        } else {
                            <div class="bg-secondary rounded d-flex align-items-center justify-content-center text-white fw-bold shadow-sm" style="width: 60px; height: 60px; font-size: 10px;">No IMG</div>
                        }
                        <div>
                            <strong class="text-primary fs-5">@item.Title</strong><br/>
                            <small class="text-muted d-inline-block text-truncate" style="max-width: 250px;">Bán kính: @item.RadiusMeters m | Ưu tiên: Level @item.Priority</small>
                        </div>
                    </td>
                    <td class="align-middle">
                        <small class="fw-bold">@item.Latitude</small><br />
                        <small class="fw-bold">@item.Longitude</small><br/>
                        @if(!string.IsNullOrEmpty(item.MapLink)){
                            <a href="@item.MapLink" target="_blank" class="badge bg-success text-decoration-none shadow-sm"><small>🔗 Google Maps</small></a>
                        }
                    </td>
                    <td class="align-middle">
                        @if(!string.IsNullOrEmpty(item.AudioUrl)){
                            <audio controls class="w-100" style="height: 35px;">
                                <source src="@item.AudioUrl" type="audio/mpeg">
                            </audio>
                        } else {
                            <span class="badge bg-info text-dark shadow-sm">Thuyết minh tự động (TTS Scripts)</span><br/>
                            <small class="text-muted d-inline-block text-truncate" style="max-width: 200px;">@item.Description</small>
                        }
                    </td>
                    <td class="align-middle text-center">
                        <div class="d-flex flex-column gap-2">
                           <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">Sửa Data</a>
                           <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Xóa Vĩnh Viễn</a>
                        </div>
                    </td>
                </tr>
        }
            </tbody>
        </table>
    </div>
</div>
