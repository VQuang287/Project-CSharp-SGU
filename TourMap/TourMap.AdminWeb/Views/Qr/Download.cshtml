@model TourMap.AdminWeb.Controllers.QrDownloadPageViewModel

@{
    ViewData["Title"] = "Tải Ứng Dụng";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-success text-white text-center py-4">
                    <h2 class="mb-0">🎧 @Model.AppName</h2>
                </div>
                <div class="card-body p-4 text-center">
                    <div class="mb-4">
                        <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px;">
                            <i class="bi bi-headphones fs-1 text-success"></i>
                        </div>
                        <h4>Tải Ứng Dụng Audio Tour</h4>
                        <p class="text-muted">Trải nghiệm thuyết minh tự động tại các điểm du lịch</p>
                    </div>

                    <div class="alert alert-warning mb-4">
                        <i class="bi bi-clock"></i>
                        <strong>Mã QR còn hiệu lực:</strong> @Model.RemainingMinutes phút nữa
                    </div>

                    <a href="@Model.ApkUrl" class="btn btn-success btn-lg w-100 mb-3" download>
                        <i class="bi bi-download"></i> Tải APK Ngay
                    </a>

                    <div class="text-muted small">
                        <p class="mb-1">Hoặc quét mã QR từ thiết bị khác</p>
                        <p class="mb-0">
                            <i class="bi bi-shield-check"></i>
                            Mã QR hết hạn lúc: @Model.ExpiresAt.ToLocalTime().ToString("HH:mm dd/MM/yyyy")
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
