@model IEnumerable<TourMap.AdminWeb.Models.QrCodeEntry>

@{
    ViewData["Title"] = "Quản Lý Mã QR";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Quản Lý Mã QR</h2>
    <a asp-action="Generate" class="btn btn-primary">+ Tạo Mã QR</a>
</div>

<div class="d-flex gap-2 mb-3">
    <input type="text" id="searchQr" class="form-control" placeholder="🔍 Tìm theo ID hoặc Link..." />
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>Mã QR</th>
            <th>POI</th>
            <th>Deep Link</th>
            <th>Ngày Tạo</th>
            <th class="text-end">Hành động</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td><img src="@item.QrImageUrl" alt="QR" style="width:80px;height:80px;" /></td>
            <td>@item.PoiId</td>
            <td><code>@item.DeepLink</code></td>
            <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
            <td class="text-end">
                <form asp-action="Delete" method="post" class="d-inline">
                    <input type="hidden" name="id" value="@item.Id" />
                    <button type="submit"
                            class="btn btn-sm btn-outline-danger"
                            onclick="return confirm('Xóa mã QR này?');">
                        Xóa
                    </button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

@section Scripts {
<script>
document.getElementById('searchQr').addEventListener('input', function () {
    var q = this.value.toLowerCase();
    document.querySelectorAll('table tbody tr').forEach(function (row) {
        row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
    });
});
</script>
}
