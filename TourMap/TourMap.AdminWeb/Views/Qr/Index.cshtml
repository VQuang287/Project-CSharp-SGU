@model IEnumerable<TourMap.AdminWeb.Models.QrCodeEntry>

@{
    ViewData["Title"] = "QR Management";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">QR Management</h2>
    <a asp-action="Generate" class="btn btn-primary">+ Generate QR</a>
</div>

<table class="table table-striped table-hover">
    <thead>
        <tr>
            <th>QR</th>
            <th>POI</th>
            <th>Deep Link</th>
            <th>Created</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var item in Model)
    {
        <tr>
            <td><img src="@item.QrImageUrl" alt="QR" style="width:80px;height:80px;" /></td>
            <td>@item.PoiId</td>
            <td><code>@item.DeepLink</code></td>
            <td>@item.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
        </tr>
    }
    </tbody>
</table>
