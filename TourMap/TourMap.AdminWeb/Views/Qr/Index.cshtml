@model TourMap.AdminWeb.Controllers.QrDownloadViewModel

@{
    ViewData["Title"] = "Tải Ứng Dụng - Mã QR";
    var expiryLocalTime = Model.ExpiresAt.ToLocalTime();
    var minutesRemaining = (int)(expiryLocalTime - DateTime.Now).TotalMinutes;
}

<div class="container py-4">
    <div class="text-center mb-4">
        <h2 class="mb-2">📱 Mã QR Tải Ứng Dụng</h2>
        <p class="text-muted">Quét mã QR để tải ứng dụng Audio Tour</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body text-center p-4">
                    <!-- QR Code Image -->
                    <div class="mb-3">
                        <img src="@Model.QrImageUrl" alt="QR Code" class="img-fluid" style="max-width: 250px;" />
                    </div>

                    <!-- Expiry Badge -->
                    <div class="mb-3">
                        @if (minutesRemaining > 0)
                        {
                            <span class="badge bg-warning text-dark fs-6">
                                ⏱️ Có hiệu lực trong @minutesRemaining phút
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger fs-6">
                                ⏱️ Đã hết hạn
                            </span>
                        }
                    </div>

                    <!-- QR Info -->
                    <div class="alert alert-light border text-start small">
                        <p class="mb-1"><strong>Tạo lúc:</strong> @Model.GeneratedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="mb-1"><strong>Hết hạn:</strong> @expiryLocalTime.ToString("dd/MM/yyyy HH:mm")</p>
                        <p class="mb-0"><strong>Thời hạn:</strong> @Model.ExpiryMinutes phút</p>
                    </div>

                    <!-- Refresh Button -->
                    <form asp-action="Regenerate" method="post" class="mt-3">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-arrow-clockwise"></i> Tạo Mã QR Mới
                        </button>
                    </form>

                    <p class="text-muted small mt-3 mb-0">
                        <i class="bi bi-info-circle"></i>
                        Mã QR sẽ tự động hết hạn sau @Model.ExpiryMinutes phút vì lý do bảo mật.
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
