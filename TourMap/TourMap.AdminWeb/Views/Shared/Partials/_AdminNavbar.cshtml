@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Dashboard";
}

<header class="admin-topbar">
    <div>
        <p class="admin-breadcrumb">Audio Tour / @pageTitle</p>
        <h1 class="admin-page-title">@pageTitle</h1>
    </div>
    <div class="admin-topbar-right">
        <span class="admin-version">v2.0.0</span>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <span class="admin-user-chip">@User.Identity.Name</span>
            <a asp-controller="Account" asp-action="Logout" class="admin-link-danger">Dang xuat</a>
        }
    </div>
</header>
