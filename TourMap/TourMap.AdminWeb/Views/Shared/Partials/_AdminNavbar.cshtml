@{
    var pageTitle = ViewData["Title"]?.ToString() ?? "Bảng Điều Khiển";
    var onlineDevices = ViewData["OnlineDevices"] ?? 0;
}

<header class="admin-topbar">
    <div>
        <p class="admin-breadcrumb">Audio Tour / @pageTitle</p>
        <h1 class="admin-page-title">@pageTitle</h1>
    </div>
    <div class="admin-topbar-right">
        <span class="admin-device-badge" title="Thiết bị đang online">
            📱 <span id="navbar-device-count">@onlineDevices</span> online
        </span>
        @if (User.Identity != null && User.Identity.IsAuthenticated)
        {
            <span class="admin-user-chip">@User.Identity.Name</span>
            <a asp-controller="Account" asp-action="Logout" class="admin-link-danger">Đăng xuất</a>
        }
    </div>
</header>
