@model TourMap.AdminWeb.ViewModels.TourEditViewModel

@{
    ViewData["Title"] = "Create Tour";
}

<h2>Create Tour</h2>
<hr />

<form asp-action="Create" method="post" class="card p-3 shadow-sm">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label"></label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label"></label>
    </div>
    <div class="mb-3">
        <label class="form-label">POIs in tour order</label>
        <select asp-for="SelectedPoiIds" asp-items="Model.AvailablePois" class="form-select" multiple size="10"></select>
        <small class="text-muted">Thứ tự chọn trong danh sách sẽ là thứ tự tour.</small>
    </div>
    <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-secondary">Back</a>
        <button type="submit" class="btn btn-primary">Save</button>
    </div>
</form>
