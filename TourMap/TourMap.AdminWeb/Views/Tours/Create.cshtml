@model TourMap.AdminWeb.ViewModels.TourEditViewModel

@{
    ViewData["Title"] = "Tạo Tour Mới";
}

<h2>Tạo Tour Mới</h2>
<hr />

<form asp-action="Create" method="post" class="card p-3 shadow-sm" id="tourForm">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="mb-3">
        <label asp-for="Name" class="form-label">Tên Tour</label>
        <input asp-for="Name" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Description" class="form-label">Mô Tả</label>
        <textarea asp-for="Description" class="form-control" rows="3"></textarea>
    </div>
    <div class="form-check mb-3">
        <input asp-for="IsActive" class="form-check-input" />
        <label asp-for="IsActive" class="form-check-label">Kích hoạt</label>
    </div>

    <div class="mb-3">
        <label class="form-label fw-bold">Danh sách POI trong tour</label>
        <div class="row g-3">
            <!-- Available POIs -->
            <div class="col-md-5">
                <div class="card border">
                    <div class="card-header bg-light py-2">
                        <small class="fw-semibold text-muted">📍 POI có sẵn</small>
                        <input type="text" id="searchAvailable" class="form-control form-control-sm mt-1" placeholder="Tìm POI..." />
                    </div>
                    <div class="card-body p-0">
                        <select id="availablePois" class="form-select border-0 rounded-0" multiple size="8" style="min-height: 200px;">
                            @foreach (var poi in Model.AvailablePois)
                            {
                                if (!(Model.SelectedPoiIds?.Contains(poi.Value) ?? false))
                                {
                                    <option value="@poi.Value">@poi.Text</option>
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>

            <!-- Buttons -->
            <div class="col-md-2 d-flex flex-column justify-content-center align-items-center gap-2">
                <button type="button" class="btn btn-primary btn-sm w-100" id="btnAdd" title="Thêm POI đã chọn">
                    Thêm ▶
                </button>
                <button type="button" class="btn btn-outline-danger btn-sm w-100" id="btnRemove" title="Xóa POI đã chọn">
                    ◀ Xóa
                </button>
                <hr class="w-100" />
                <button type="button" class="btn btn-outline-secondary btn-sm w-100" id="btnUp" title="Di chuyển lên">
                    ▲ Lên
                </button>
                <button type="button" class="btn btn-outline-secondary btn-sm w-100" id="btnDown" title="Di chuyển xuống">
                    ▼ Xuống
                </button>
            </div>

            <!-- Selected POIs -->
            <div class="col-md-5">
                <div class="card border border-primary">
                    <div class="card-header bg-primary text-white py-2">
                        <small class="fw-semibold">🗺️ POI trong tour (theo thứ tự)</small>
                    </div>
                    <div class="card-body p-0">
                        <select id="selectedPois" class="form-select border-0 rounded-0" multiple size="8" style="min-height: 200px;">
                            @if (Model.SelectedPoiIds != null)
                            {
                                @foreach (var id in Model.SelectedPoiIds)
                                {
                                    var poi = Model.AvailablePois.FirstOrDefault(p => p.Value == id);
                                    if (poi != null)
                                    {
                                        <option value="@poi.Value">@poi.Text</option>
                                    }
                                }
                            }
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- Hidden inputs for form submission -->
        <div id="hiddenInputs"></div>
    </div>

    <div class="d-flex gap-2 justify-content-end">
        <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        <button type="submit" class="btn btn-primary">Lưu</button>
    </div>
</form>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    var available = document.getElementById('availablePois');
    var selected = document.getElementById('selectedPois');
    var searchBox = document.getElementById('searchAvailable');
    var form = document.getElementById('tourForm');

    // Search filter
    searchBox.addEventListener('input', function () {
        var query = this.value.toLowerCase();
        Array.from(available.options).forEach(function (opt) {
            opt.style.display = opt.text.toLowerCase().includes(query) ? '' : 'none';
        });
    });

    // Add POI
    document.getElementById('btnAdd').addEventListener('click', function () {
        moveOptions(available, selected);
    });

    // Remove POI
    document.getElementById('btnRemove').addEventListener('click', function () {
        moveOptions(selected, available);
    });

    // Move Up
    document.getElementById('btnUp').addEventListener('click', function () {
        var opts = selected.selectedOptions;
        for (var i = 0; i < opts.length; i++) {
            var opt = opts[i];
            if (opt.previousElementSibling) {
                opt.parentNode.insertBefore(opt, opt.previousElementSibling);
            }
        }
    });

    // Move Down
    document.getElementById('btnDown').addEventListener('click', function () {
        var opts = Array.from(selected.selectedOptions);
        for (var i = opts.length - 1; i >= 0; i--) {
            var opt = opts[i];
            if (opt.nextElementSibling) {
                opt.parentNode.insertBefore(opt.nextElementSibling, opt);
            }
        }
    });

    // Double-click to move
    available.addEventListener('dblclick', function () { moveOptions(available, selected); });
    selected.addEventListener('dblclick', function () { moveOptions(selected, available); });

    function moveOptions(from, to) {
        var opts = Array.from(from.selectedOptions);
        opts.forEach(function (opt) {
            from.removeChild(opt);
            to.appendChild(opt);
            opt.selected = false;
        });
    }

    // Before submit: create hidden inputs
    form.addEventListener('submit', function () {
        var container = document.getElementById('hiddenInputs');
        container.innerHTML = '';
        Array.from(selected.options).forEach(function (opt) {
            var input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'SelectedPoiIds';
            input.value = opt.value;
            container.appendChild(input);
        });
    });
});
</script>
}
