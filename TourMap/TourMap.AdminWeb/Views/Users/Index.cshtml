@model List<TourMap.AdminWeb.Models.MobileUser>
@{
    ViewData["Title"] = "Quản lý người dùng";
    var search = ViewData["Search"] as string;
    var roleFilter = ViewData["Role"] as string;
    var totalUsers = ViewData["TotalUsers"];
    var totalRegistered = ViewData["TotalRegistered"];
    var totalGuests = ViewData["TotalGuests"];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2 class="mb-1">👥 Quản lý người dùng</h2>
        <p class="text-muted mb-0">Tổng: <strong>@totalUsers</strong> | Đã đăng ký: <strong>@totalRegistered</strong> | Khách: <strong>@totalGuests</strong></p>
    </div>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-3">
            <div class="col-md-6">
                <input type="text" name="search" value="@search" class="form-control" placeholder="Tìm theo email, tên, hoặc Device ID..." />
            </div>
            <div class="col-md-3">
                <select name="role" class="form-select">
                    <option value="">Tất cả role</option>
                    <option value="Guest" selected="@(roleFilter == "Guest")">Guest</option>
                    <option value="User" selected="@(roleFilter == "User")">User</option>
                    <option value="Premium" selected="@(roleFilter == "Premium")">Premium</option>
                    <option value="Banned" selected="@(roleFilter == "Banned")">Banned</option>
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary w-100">🔍 Tìm kiếm</button>
            </div>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">@TempData["Success"]</div>
}

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Người dùng</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Provider</th>
                    <th>Đăng nhập lần cuối</th>
                    <th>Ngày tạo</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    var roleBadge = user.Role switch
                    {
                        "Guest" => "bg-secondary",
                        "User" => "bg-primary",
                        "Premium" => "bg-warning text-dark",
                        "Banned" => "bg-danger",
                        _ => "bg-secondary"
                    };
                    <tr>
                        <td>
                            <div class="d-flex align-items-center">
                                <div class="rounded-circle bg-light d-flex align-items-center justify-content-center me-2" style="width:36px;height:36px;font-size:14px;">
                                    @(string.IsNullOrEmpty(user.Email) ? "👤" : user.DisplayName[..1].ToUpper())
                                </div>
                                <div>
                                    <strong>@user.DisplayName</strong>
                                    <br /><small class="text-muted">@user.DeviceId[..Math.Min(8, user.DeviceId.Length)]...</small>
                                </div>
                            </div>
                        </td>
                        <td>@(user.Email ?? "<em class='text-muted'>Ẩn danh</em>")</td>
                        <td><span class="badge @roleBadge">@user.Role</span></td>
                        <td><small>@user.AuthProvider</small></td>
                        <td><small>@user.LastLoginAt.ToString("dd/MM HH:mm")</small></td>
                        <td><small>@user.CreatedAt.ToString("dd/MM/yyyy")</small></td>
                        <td>
                            <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-outline-primary">Chi tiết</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
